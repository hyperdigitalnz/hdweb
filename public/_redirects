# 301 redirects from the old hyperdigital.nz site to the new pages.
# Format: <old path>  <new path>  <status>. First match wins.
# Cloudflare serves these from the static-assets dir (same as _headers).
# Note: only relative URLs are allowed here. www → apex is handled by a
# Cloudflare Redirect Rule in the dashboard, not this file.
# Rules do NOT auto-match trailing slashes (verified 03/07/2026: /google-ads
# redirected while /google-ads/ 404'd), so every path is listed in both forms.

# Service pages → closest new equivalent
# /google-ads is a real page again (20/07/2026). It used to 301 to /lead-generation,
# which cost us the ads-management intent: GSC showed the old URL still ranking while
# the destination page talked about tradie lead gen. Do NOT re-add a rule for it here,
# a _redirects entry would shadow the page.
/paid-ads                  /google-ads        301
/paid-ads/                 /google-ads        301
/digital-marketing         /lead-generation   301
/digital-marketing/        /lead-generation   301
/targeted-marketing        /lead-generation   301
/targeted-marketing/       /lead-generation   301
/seo                       /lead-generation   301
/seo/                      /lead-generation   301
/social-media              /lead-generation   301
/social-media/             /lead-generation   301
/websites-and-e-commerce   /websites          301
/websites-and-e-commerce/  /websites          301
/ai                        /ai-automation     301
/ai/                       /ai-automation     301
/services                  /                  301
/services/                 /                  301
/training                  /                  301
/training/                 /                  301

# Hawke's Bay local pages moved under /insights (11/07/2026)
/seo-hawkes-bay                 /insights/seo-hawkes-bay                 301
/seo-hawkes-bay/                /insights/seo-hawkes-bay                 301
/digital-marketing-hawkes-bay   /insights/digital-marketing-hawkes-bay   301
