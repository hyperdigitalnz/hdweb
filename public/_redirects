# 301 redirects from the old hyperdigital.nz site to the new pages.
# Format: <old path>  <new path>  <status>. First match wins.
# Cloudflare serves these from the static-assets dir (same as _headers).

# Canonical host: send www → non-www (apex). The authoritative enforcement is a
# Cloudflare Redirect Rule; this is a best-effort fallback at the assets layer.
https://www.hyperdigital.nz/*  https://hyperdigital.nz/:splat  301!

# Service pages → closest new equivalent
/google-ads               /lead-generation   301
/digital-marketing        /lead-generation   301
/targeted-marketing       /lead-generation   301
/seo                      /lead-generation   301
/social-media             /lead-generation   301
/websites-and-e-commerce  /websites          301
/ai                       /ai-automation     301
/services                 /                  301
/training                 /                  301

# Conversion / contact pages (/thank-you is a real page — form success lands there)
/book-an-appointment      /contact           301
/free-consultation        /contact           301

# Legal + about
/terms-and-conditions     /terms             301
/privacy-policy           /privacy           301
/about-us                 /about             301
