---
// Native lead form → /api/lead (verifies Turnstile → GHL webhook). Progressive enhancement:
// posts via fetch, shows on-page success, fires gtag conversion on verified success.
interface Props {
  title?: string;
  lead?: string;
  compact?: boolean;
  goal?: boolean;
}
const {
  title = "Book your free audit",
  lead = "Tell us about your business and we'll show you where your next jobs are coming from.",
  compact = false,
  goal = false,
} = Astro.props;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const trades = ["Plumber","Electrician","Roofer","Builder","HVAC / Air Con","Painter / Decorator","Auto / Mechanic","Other trade"];
---
<div class="rounded-box border-t-4 border-primary bg-base-100 p-6 text-base-content shadow-xl sm:p-7">
  <h2 class="text-2xl text-base-content">{title}</h2>
  <p class="mt-2 text-sm text-base-content/70">{lead}</p>

  <form class="audit-form mt-5 grid gap-3" method="post" action="/api/lead">
    <!-- Honeypot: hidden from real users, catches bots. Keep it unlabelled and out of the tab order. -->
    <div class="hidden" aria-hidden="true">
      <label for="af-company">Company (leave blank)</label>
      <input id="af-company" name="company" type="text" tabindex="-1" autocomplete="off" />
    </div>
    <div class="grid gap-1">
      <label class="text-xs font-bold" for="af-name">Your name</label>
      <input id="af-name" name="name" type="text" required autocomplete="name" placeholder="Jane Smith" class="input input-bordered w-full" />
    </div>
    <div class="grid gap-1">
      <label class="text-xs font-bold" for="af-phone">Mobile number</label>
      <input id="af-phone" name="phone" type="tel" required autocomplete="tel" placeholder="027 123 4567" class="input input-bordered w-full" />
    </div>
    <div class="grid gap-1">
      <label class="text-xs font-bold" for="af-trade">Your trade / business</label>
      <select id="af-trade" name="trade" required class="select select-bordered w-full">
        <option value="" disabled selected>Select one…</option>
        {trades.map((t) => <option>{t}</option>)}
      </select>
    </div>
    {!compact && (
      <div class="grid gap-1">
        <label class="text-xs font-bold" for="af-region">Region</label>
        <input id="af-region" name="region" type="text" autocomplete="address-level1" placeholder="e.g. Hawke's Bay" class="input input-bordered w-full" />
      </div>
    )}
    {goal && (
      <div class="grid gap-1">
        <label class="text-xs font-bold" for="af-goal">What's your goal right now? <span class="font-normal text-base-content/50">(optional)</span></label>
        <select id="af-goal" name="goal" class="select select-bordered w-full">
          <option value="" disabled selected>Select one…</option>
          <option>More leads</option>
          <option>A new website</option>
          <option>More reviews / repeat work</option>
          <option>Not sure yet</option>
        </select>
      </div>
    )}

    {siteKey && <div class="cf-turnstile" data-sitekey={siteKey}></div>}

    <button type="submit" class="btn btn-primary btn-block font-display text-lg tracking-wide">Get my free audit →</button>
    <p class="form-msg text-center text-xs text-base-content/60" aria-live="polite">
      ⚡ We reply within one business day. We only take on a handful of new clients a month.
    </p>
  </form>
</div>

{siteKey && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}

<script>
  function wireForms() {
    document.querySelectorAll<HTMLFormElement>(".audit-form").forEach((form) => {
      if (form.dataset.wired) return;
      form.dataset.wired = "1";
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const msg = form.querySelector<HTMLElement>(".form-msg");
        const btn = form.querySelector<HTMLButtonElement>("button[type=submit]");
        if (btn) { btn.disabled = true; btn.textContent = "Sending…"; }
        try {
          const res = await fetch(form.action, { method: "POST", body: new FormData(form) });
          const data = await res.json().catch(() => ({ ok: res.ok }));
          if (data.ok) {
            // fire Google Ads conversion on verified success
            if (typeof (window as any).gtag === "function") {
              (window as any).gtag("event", "conversion", { send_to: "AW-703611224/KEGlCPfXyr4cENiCwc8C" });
            }
            form.innerHTML =
              '<div class="py-6 text-center"><div class="text-4xl">✅</div>' +
              '<h2 class="mt-3 text-2xl text-base-content">You\'re booked in!</h2>' +
              '<p class="mt-2 text-sm text-base-content/70">We\'ll be in touch within one business day with your free audit.</p></div>';
          } else {
            throw new Error(data.error || "failed");
          }
        } catch (err) {
          if (msg) { msg.textContent = "Something went wrong. Please call us on 027 666 1973."; msg.classList.add("text-error"); }
          if (btn) { btn.disabled = false; btn.textContent = "Get my free audit →"; }
        }
      });
    });
  }
  document.addEventListener("astro:page-load", wireForms);
</script>
