---
// Automation sequence visual: a vertical pipeline where each node pulses in turn (cascade),
// showing the loop that runs in the background. On-brand black + gold.
import Icon from "./Icon.astro";

const nodes = [
  { icon: "phone", tag: "Missed call", text: "Texted back before they ring the next tradie" },
  { icon: "chat", tag: "Follow-up", text: "Chases the quote until they book or say no" },
  { icon: "calendar", tag: "Job booked", text: "Lands in your calendar automatically" },
  { icon: "star", tag: "Review request", text: "Sent the moment the job's marked done" },
  { icon: "trend", tag: "More leads", text: "Reviews lift your ranking, and the cycle repeats" },
];
---
<div class="mx-auto w-full max-w-sm">
  <div class="rounded-[2rem] border border-white/10 surface-2 p-5 shadow-2xl sm:p-6">
    <div class="flex items-center justify-between px-1 pb-4">
      <span class="text-xs font-bold uppercase tracking-wide text-neutral-content/60">Working in the background</span>
      <span class="flex items-center gap-1.5 text-xs text-primary">
        <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-primary"></span> Always on
      </span>
    </div>

    <div class="relative">
      <!-- connector line behind the nodes (chip centre = 1.5rem) -->
      <span class="absolute left-6 top-6 bottom-6 w-px -translate-x-1/2 bg-gradient-to-b from-primary/60 via-primary/30 to-primary/60"></span>
      {nodes.map((n, i) => (
        <div class="relative flex items-start gap-4 pb-5 last:pb-0">
          <span class="icon-chip flow-pulse z-10 shrink-0 surface-3" style={`animation-delay:${i * 1.4}s`}>
            <Icon name={n.icon} class="h-5 w-5" />
          </span>
          <div class="min-w-0 pt-1.5">
            <span class="badge badge-sm badge-primary font-display">{n.tag}</span>
            <p class="mt-1 text-sm text-neutral-content/80">{n.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
  <p class="mt-3 text-center text-xs text-neutral-content/50">Set it up once. It runs itself.</p>
</div>
