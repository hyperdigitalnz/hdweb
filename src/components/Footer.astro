---
import { SITE, NAV, STATS_NOTE } from "../consts";
---
<footer class="bg-neutral text-neutral-content/70">
  <div class="mx-auto max-w-[1160px] px-5 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href="/" aria-label="Hyper Digital home" class="logo inline-block text-2xl text-neutral-content transition-colors hover:text-primary">HYPER<span class="text-primary">DIGITAL</span></a>
        <p class="mt-3 text-sm">{SITE.tagline}</p>
        <p class="mt-2 text-sm">{SITE.location}</p>
      </div>

      <nav class="flex flex-col gap-2 text-sm">
        {NAV.map((item) => <a href={item.href} class="transition-colors hover:text-primary">{item.label}</a>)}
        <a href="/contact" class="transition-colors hover:text-primary">Contact</a>
      </nav>

      <div class="text-sm">
        <a href={SITE.phoneHref} class="font-display text-2xl text-neutral-content transition-colors hover:text-primary">{SITE.phone}</a>
        <p class="mt-2">{SITE.hours}</p>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs sm:flex-row sm:items-center sm:justify-between">
      <span class="text-center sm:text-left">© {new Date().getFullYear()} {SITE.name}</span>
      <div class="flex items-center justify-center gap-4 sm:gap-6">
        <img src="/img/google-ads-partner-badge.png" alt="Google Ads Partner" width="240" height="80" loading="lazy" class="max-h-16 w-auto max-w-[44%] object-contain sm:max-h-24" />
        <img src="/img/meta-business-partner-badge.jpg" alt="Meta Business Partner" width="240" height="80" loading="lazy" class="max-h-16 w-auto max-w-[44%] rounded object-contain sm:max-h-24" />
      </div>
      <div class="flex justify-center gap-4 sm:justify-start">
        <a href="/privacy" class="transition-colors hover:text-primary">Privacy</a>
        <a href="/terms" class="transition-colors hover:text-primary">Terms</a>
      </div>
    </div>

    <p class="mt-6 text-xs text-neutral-content/40">* {STATS_NOTE}</p>
  </div>
</footer>
