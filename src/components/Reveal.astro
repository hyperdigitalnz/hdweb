---
// Wraps content in a scroll-reveal container. Animated by the Motion script in Layout.astro.
interface Props {
  delay?: number;
  class?: string;
  id?: string;
}
const { delay = 0, class: className = "", id } = Astro.props;
---
<div data-reveal data-reveal-delay={delay} class={className} id={id}>
  <slot />
</div>
