---
// Avatar stack + stars + count (fa.st-style social proof row).
interface Props {
  tone?: "dark" | "light";
}
const { tone = "dark" } = Astro.props;
const ring = tone === "dark" ? "ring-neutral" : "ring-base-100";
const sub = tone === "dark" ? "text-neutral-content/80" : "text-base-content/70";
const strong = tone === "dark" ? "text-neutral-content" : "text-base-content";

const avatars = [
  { src: "/img/denise-bermuda-lifestyle-avatar.jpg", alt: "Denise, Bermuda Lifestyle" },
  { src: "/img/tableau-towbars-avatar.png", alt: "Tableau Towbars" },
  { src: "/img/harris-pumps-avatar.png", alt: "Harris Pumps" },
  { src: "/img/continous-spouting-avatar.png", alt: "Continuous Spouting" },
  { src: "/img/wade-motordrome-avatar.png", alt: "Wade, Motordrome" },
];
---
<div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
  <div class="flex -space-x-3">
    {avatars.map((a) => (
      <img
        src={a.src}
        alt={a.alt}
        loading="lazy"
        decoding="async"
        class={`h-10 w-10 rounded-full object-cover object-center bg-neutral ring-2 ${ring}`}
      />
    ))}
  </div>
  <div class="text-left">
    <div class="leading-none text-primary">★★★★★</div>
    <div class={`text-sm ${sub}`}>Trusted by <span class={`font-bold ${strong}`}>40+ Kiwi tradies</span></div>
  </div>
</div>
