---
// Mobile-only bottom bar, mounted site-wide by Layout. SSR/no-JS state is plain
// tap-to-call; during the callback window (consts.ts CALLBACK) a client script swaps
// it to "Request a callback" → /callback. Trade LPs pass callback={false}
// so paid traffic keeps the pure tel: bar and never gets routed off the page.
import { CALLBACK, SITE } from "../consts";
import Icon from "./Icon.astro";

interface Props {
  callback?: boolean;
}
const { callback = true } = Astro.props;
---
<a
  href={SITE.phoneHref}
  class="sticky-call fixed inset-x-0 bottom-0 z-[60] flex items-center justify-center gap-2 bg-primary py-3.5 font-display
         text-xl tracking-wide text-primary-content shadow-[0_-4px_16px_rgba(0,0,0,0.3)] sm:hidden"
  data-callback={callback ? "1" : undefined}
  data-callback-label={CALLBACK.openLabel}
  data-call-label={`Tap to call ${SITE.phone}`}
  data-call-href={SITE.phoneHref}
>
  <Icon name="phone" class="h-5 w-5" />
  <span class="sticky-call-label">Tap to call {SITE.phone}</span>
</a>

<script>
  import { isCallbackOpen } from "../consts";

  // Runs on initial load and after every soft navigation, and handles both directions
  // (a callback-enabled page after an LP, and vice versa).
  function updateStickyCall() {
    document.querySelectorAll<HTMLAnchorElement>(".sticky-call").forEach((bar) => {
      const label = bar.querySelector<HTMLElement>(".sticky-call-label");
      if (!label) return;
      if (bar.dataset.callback === "1" && isCallbackOpen()) {
        bar.href = "/callback";
        label.textContent = bar.dataset.callbackLabel ?? label.textContent;
      } else {
        bar.href = bar.dataset.callHref ?? bar.href;
        label.textContent = bar.dataset.callLabel ?? label.textContent;
      }
    });
  }

  document.addEventListener("astro:page-load", updateStickyCall);
</script>
