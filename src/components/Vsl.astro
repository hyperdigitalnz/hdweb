---
// Video sales letter block. Responsive 16:9, click-to-play (no autoplay),
// rounded with a gold brand glow. Served straight from the CDN.
interface Props {
  src: string;
  poster?: string;
  caption?: string;
  class?: string;
}
const { src, poster, caption, class: cls = "" } = Astro.props;
---
<figure class={`m-0 ${cls}`}>
  <div class="overflow-hidden rounded-box border border-primary/30 shadow-2xl shadow-primary/20">
    <video
      class="aspect-video w-full bg-black"
      controls
      preload="metadata"
      playsinline
      poster={poster}
    >
      <source src={src} type="video/mp4" />
      Your browser does not support the video tag.
      <a href={src}>Watch the video</a>.
    </video>
  </div>
  {caption && (
    <figcaption class="mt-3 text-center text-sm text-neutral-content/60">{caption}</figcaption>
  )}
</figure>
