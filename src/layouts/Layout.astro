---
import "../styles/global.css";
// Self-hosted fonts: Outfit variable (all weights, registers "Outfit Variable")
// + Source Sans 3 at 800 only (SVG chart labels reference "Source Sans 3").
import "@fontsource-variable/outfit";
import "@fontsource/source-sans-3/800.css";
import outfitWoff2 from "@fontsource-variable/outfit/files/outfit-latin-wght-normal.woff2?url";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  /** Hide the site nav header. Used on paid-traffic landing pages to remove
   *  exit links and keep focus on the form. */
  hideHeader?: boolean;
  /** Hide the footer too. Used by chrome-free utility pages like /links. */
  hideFooter?: boolean;
  /** Hide the chat widget. The 404 page must set this explicitly because it
   *  renders under the requested (missing) URL, not a fixed path. */
  hideChat?: boolean;
}
const {
  title = `${SITE.name} | ${SITE.tagline}`,
  description = "The complete job booking system for modern Tradies. We find you the work, book it 24/7, and keep your calendar full. Free leads audit.",
  image = "/img/digital-marketing.png",
  noindex = false,
  hideHeader = false,
  hideFooter = false,
  hideChat = false,
} = Astro.props;

// Absolute URLs for canonical + social cards (needs `site` in astro.config).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// Chat widget shows everywhere except these pages. ClientRouter swaps each
// page's server-rendered body on navigation, so this per-path check stays
// correct without client-side logic.
const noChatPaths = ["/privacy", "/terms", "/thank-you", "/404"];
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const showChat = !hideChat && !noChatPaths.includes(currentPath);
---
<!doctype html>
<html lang="en-NZ" data-theme="hyper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-48.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0c0b0a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_NZ" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preload the display font: the LCP element (header logo text) renders in it,
         so having it by first paint avoids a late font-swap repaint. -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href={outfitWoff2} />

    <ClientRouter />

    <!-- Google Tag Manager (GTM-KXHVKNQ): FB pixel, GA4, Clarity/Hotjar etc. all live in GTM.
         Tag changes happen in the GTM UI/API, not this codebase. -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-KXHVKNQ');
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google Ads global tag (conversion id from runlog) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-703611224"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", "AW-703611224");
    </script>

    <!-- mark JS available so reveal elements can hide pre-animation (no FOUC for no-JS) -->
    <script is:inline>document.documentElement.classList.add("js");</script>
  </head>
  <body class="bg-base-100 text-base-content">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KXHVKNQ"
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {!hideHeader && <Header />}
    <main>
      <slot />
    </main>
    {!hideFooter && <Footer />}

    <!-- DO NOT mount anything fixed to the bottom of the mobile viewport here (a sticky
         call/callback bar lived here briefly on 03/07/2026 and was removed): the GHL
         chatbot embed below occupies that area on mobile and blocks/covers it. -->

    <!-- LeadConnector chat widget (hidden on privacy, terms, thank-you, 404) -->
    {showChat && (
      <script
        is:inline
        async
        src="https://widgets.leadconnectorhq.com/loader.js"
        data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js"
        data-widget-id="695ff09578e0acf0ed3bf73d"
      ></script>
    )}

    <!-- Scroll-reveal animations via Motion (re-runs after view transitions) -->
    <script>
      import { animate, inView } from "motion";

      function setupReveal() {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
          if (el.dataset.revealed) return;
          el.dataset.revealed = "1";
          if (reduce) { el.style.opacity = "1"; el.style.transform = "none"; return; }
          const delay = parseFloat(el.dataset.revealDelay || "0");
          inView(
            el,
            () => {
              animate(
                el,
                { opacity: [0, 1], transform: ["translateY(16px)", "translateY(0px)"] },
                { duration: 0.6, delay, ease: [0.16, 1, 0.3, 1] }
              );
            },
            { amount: 0.2 }
          );
        });
      }
      document.addEventListener("astro:page-load", setupReveal);
    </script>
  </body>
</html>
