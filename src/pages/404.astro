---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import { SITE } from "../consts";

const title = "Page not found | Hyper Digital";
const description = "Sorry, we couldn't find that page. Head back home or get in touch.";

const links = [
  { href: "/websites", label: "Smart websites" },
  { href: "/lead-generation", label: "Lead generation" },
  { href: "/ai-automation", label: "AI automation" },
  { href: "/results", label: "Results" },
];
---
<Layout title={title} description={description} noindex={true} hideChat={true}>
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[820px] px-5 py-24 text-center sm:py-32">
      <Reveal>
        <span class="eyebrow">Error 404</span>
        <h1 class="mt-3 text-5xl sm:text-6xl">This page took a <span class="marker">wrong turn</span>.</h1>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="mx-auto max-w-xl text-lg text-neutral-content/80">
          The page you're after has moved or no longer exists. Let's get you back on track.
        </p>
      </Reveal>
      <Reveal delay={0.14} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
        <a href="/" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Back to home</a>
        <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
      </Reveal>
      <Reveal delay={0.2} class="mt-10">
        <p class="text-sm uppercase tracking-wider text-neutral-content/50">Popular pages</p>
        <div class="mt-3 flex flex-wrap justify-center gap-x-5 gap-y-2">
          {links.map((l) => (
            <a href={l.href} class="text-primary transition-colors hover:text-secondary">{l.label}</a>
          ))}
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
