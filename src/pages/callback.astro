---
// Standalone home for the callback form (Matt didn't want it stacked on /contact).
// Reached from the mobile sticky bar during the callback window; noindex utility page.
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import CallbackForm from "../components/CallbackForm.astro";
import { SITE } from "../consts";

const title = "Request a callback | Hyper Digital";
const description =
  "Leave your name and number and one of the owners will ring you back. No call centre, no pressure.";
---
<Layout title={title} description={description} noindex={true} stickyCallback={false}>
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[820px] px-5 py-16 sm:py-24">
      <Reveal class="text-center">
        <span class="eyebrow">Callback</span>
        <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl">We'll <span class="marker">ring you</span>.</h1>
      </Reveal>
      <Reveal delay={0.08} class="mt-5 text-center">
        <p class="mx-auto max-w-xl text-lg text-neutral-content/80">
          Not a fan of forms or waiting on hold? Leave your name and number and you'll get a call
          from one of the owners, not a call centre.
        </p>
      </Reveal>
      <Reveal delay={0.14} class="mx-auto mt-10 max-w-md">
        <CallbackForm />
      </Reveal>
      <Reveal delay={0.2} class="mt-8 text-center">
        <a href={SITE.phoneHref} class="text-sm uppercase tracking-wider text-neutral-content/50 transition-colors hover:text-primary">
          Or call us now on {SITE.phone}
        </a>
      </Reveal>
    </div>
  </section>
</Layout>
