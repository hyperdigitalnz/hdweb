---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import AuditForm from "../components/AuditForm.astro";
import SocialProof from "../components/SocialProof.astro";
import Icon from "../components/Icon.astro";
import { SITE } from "../consts";

const title = "Contact Hyper Digital | Get Your Free Audit";
const description =
  "Get your free, no-obligation marketing audit. Call 027 666 1973 or send us a few details and we'll show you where your next jobs are coming from.";

const steps = [
  { n: "1", icon: "chat", title: "We get in touch", body: "We'll be in touch within one business day. No call centre, you get one of the owners." },
  { n: "2", icon: "search", title: "We show you what's real", body: "We look at your trade, your area and your numbers, and show you what's realistic." },
  { n: "3", icon: "phone", title: "Your phone starts ringing", body: "If it's a fit, we get your system built and the booked jobs coming in." },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Hyper Digital",
  url: "https://hyperdigital.nz",
  telephone: "+64276661973",
  areaServed: "NZ",
  address: { "@type": "PostalAddress", addressRegion: "Hawke's Bay", addressCountry: "NZ" },
  ...(SITE.email ? { email: SITE.email } : {}),
};
---
<Layout title={title} description={description}>
  <!-- ===== HERO + FORM ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto grid grid-cols-1 max-w-[1160px] items-start gap-12 px-5 py-16 sm:py-20 lg:grid-cols-2">
      <div class="text-center lg:text-left">
        <Reveal>
          <span class="eyebrow">Contact</span>
        </Reveal>
        <Reveal delay={0.05} class="mt-3">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl">Get your <span class="marker">free audit</span>.</h1>
        </Reveal>
        <Reveal delay={0.1} class="mt-6">
          <p class="mx-auto max-w-xl text-lg text-neutral-content/80 lg:mx-0">
            Tell us about your business and we'll show you exactly where your next jobs are coming
            from, and what they'll cost. No jargon, no obligation.
          </p>
        </Reveal>

        <Reveal delay={0.15} class="mt-8">
          <ul class="mx-auto grid max-w-md gap-3 text-left lg:mx-0">
            <li>
              <a href={SITE.phoneHref} class="flex items-center gap-3 rounded-box border border-white/10 bg-white/5 p-4 transition-colors hover:border-primary/50">
                <span class="icon-chip shrink-0"><Icon name="phone" class="h-5 w-5" /></span>
                <span>
                  <span class="block text-xs uppercase tracking-wide text-neutral-content/60">Phone (tap to call)</span>
                  <span class="font-display text-lg">{SITE.phone}</span>
                </span>
              </a>
            </li>
            {SITE.email && (
              <li>
                <a href={`mailto:${SITE.email}`} class="flex items-center gap-3 rounded-box border border-white/10 bg-white/5 p-4 transition-colors hover:border-primary/50">
                  <span class="icon-chip shrink-0"><Icon name="mail" class="h-5 w-5" /></span>
                  <span>
                    <span class="block text-xs uppercase tracking-wide text-neutral-content/60">Email</span>
                    <span class="font-display text-lg">{SITE.email}</span>
                  </span>
                </a>
              </li>
            )}
            <li class="flex items-center gap-3 rounded-box border border-white/10 bg-white/5 p-4">
              <span class="icon-chip shrink-0"><Icon name="clock" class="h-5 w-5" /></span>
              <span>
                <span class="block text-xs uppercase tracking-wide text-neutral-content/60">Hours</span>
                <span class="font-display text-lg">{SITE.hours}</span>
              </span>
            </li>
            <li class="flex items-center gap-3 rounded-box border border-white/10 bg-white/5 p-4">
              <span class="icon-chip shrink-0"><Icon name="pin" class="h-5 w-5" /></span>
              <span>
                <span class="block text-xs uppercase tracking-wide text-neutral-content/60">Based in</span>
                <span class="font-display text-lg">Hawke's Bay, working NZ-wide</span>
              </span>
            </li>
          </ul>
        </Reveal>

        <Reveal delay={0.22} class="mt-8">
          <SocialProof />
        </Reveal>
      </div>

      <Reveal delay={0.1} class="lg:sticky lg:top-24">
        <AuditForm
          goal
          title="Book your free audit"
          lead="Tell us about your business and we'll show you where your next jobs are coming from, and what they'll cost."
        />
      </Reveal>
    </div>
  </section>

  <!-- ===== WHAT HAPPENS NEXT ===== -->
  <section class="bg-grid-soft border-t border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">What's next</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">What happens after you hit send.</h2>
      </Reveal>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {steps.map((s, i) => (
          <Reveal delay={i * 0.08} class="h-full">
            <div class="card h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body">
                <div class="flex items-center justify-between">
                  <span class="icon-chip"><Icon name={s.icon} class="h-6 w-6" /></span>
                  <span class="font-display text-3xl text-base-300">{s.n}</span>
                </div>
                <h3 class="mt-3 font-display text-xl">{s.title}</h3>
                <p class="mt-1 text-base-content/70">{s.body}</p>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
      <Reveal class="mt-10 text-center">
        <p class="text-lg text-base-content/70">In a hurry? Just call us.</p>
        <a href={SITE.phoneHref} class="btn btn-primary mt-4 font-display text-lg tracking-wide">Call {SITE.phone}</a>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />
</Layout>
