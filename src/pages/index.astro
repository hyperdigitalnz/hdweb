---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import Icon from "../components/Icon.astro";
import AuditForm from "../components/AuditForm.astro";
import SocialProof from "../components/SocialProof.astro";
import PricingTiers from "../components/PricingTiers.astro";
import SpeedBadge from "../components/SpeedBadge.astro";
import LeadFeed from "../components/LeadFeed.astro";
import ChatDemo from "../components/ChatDemo.astro";
import { SITE, STATS } from "../consts";
import { SETUP_FEE } from "../data/pricing";

const trades = [
  { name: "Plumbers", icon: "droplet" },
  { name: "Electricians", icon: "bolt" },
  { name: "Roofers", icon: "home" },
  { name: "Builders", icon: "hammer" },
  { name: "HVAC & Air Con", icon: "flame" },
  { name: "Painters", icon: "paint" },
  { name: "Auto & Mechanical", icon: "cog" },
  { name: "Drainlayers", icon: "wrench" },
  { name: "Landscapers", icon: "leaf" },
  { name: "Concrete", icon: "blocks" },
];

const missed = [
  { icon: "phone-missed", title: "Missed call", meta: "Unknown number · 9:47am", tilt: "-rotate-2" },
  { icon: "voicemail", title: "Voicemail", meta: "No message left · 11:15am", tilt: "rotate-1" },
  { icon: "phone-missed", title: "Missed call", meta: "While you were quoting · 11:52am", tilt: "-rotate-1" },
];

const alone = [
  "Calls go to voicemail while you're on the tools.",
  "Quotes you meant to chase, but never did.",
  "Ad money spent with nothing to show for it.",
  "Happy customers who never leave a review.",
  "Marketing decisions made by gut feel at 9pm.",
];

const withUs = [
  "Every website enquiry answered in 30 seconds, day or night.",
  "Leads followed up automatically until they book or say no.",
  "Every dollar tracked, reported and accounted for.",
  "Reviews requested after every job, on autopilot.",
  "One system, fully managed, while you stay on the tools.",
];

const system = [
  {
    n: "01",
    icon: "target",
    title: "Find the work",
    body: "Tight Google Ads campaigns put you in front of ready-to-buy locals the moment they search. Local SEO keeps you climbing over time. Real calls and quote requests, not vanity clicks.",
  },
  {
    n: "02",
    icon: "calendar-check",
    title: "Book the work",
    body: "Your smart website and AI assistant answer, qualify and book every enquiry in 30 seconds. Even at 11pm, while you're off the clock.",
  },
  {
    n: "03",
    icon: "repeat",
    title: "Keep it coming",
    body: "Automatic follow-ups chase every quote until it's a yes or a no. Reviews roll in after every job. Past customers get a nudge when it's time to book again.",
  },
];

const steps = [
  {
    n: "1",
    title: "The free audit",
    body: "20 minutes. We look at your trade, your area and your competition, then give you real numbers on what's possible. No jargon, no pressure.",
  },
  {
    n: "2",
    title: "We build your system",
    body: "Smart website, campaigns, automation. Built and switched on within days, without you lifting a finger.",
  },
  {
    n: "3",
    title: "Your phone starts ringing",
    body: "Booked jobs land in your calendar. We report the real numbers every month and keep tuning to bring your cost per job down.",
  },
];

const clientLogos = [
  { src: "/img/continuousGroupLogoBW.png", alt: "Continuous Group", w: 300, h: 180 },
  { src: "/img/no-drips-logo.png", alt: "No Drips Waterproofing", w: 329, h: 247 },
  { src: "/img/boulevardServicesLogoBW.png", alt: "Boulevard Services", w: 300, h: 180 },
  // White logo, invisible on the light section background — gets a dark backing box.
  { src: "/img/harcourtsLogoBW.png", alt: "Harcourts", darkBox: true, w: 297, h: 74 },
  { src: "/img/portaSkipLogoBW.png", alt: "Porta Skip", w: 250, h: 116 },
  { src: "/img/toplineLogoBW.png", alt: "Topline", w: 300, h: 180 },
  { src: "/img/hawksBayCombinedTaxisLogoBW.png", alt: "Hawke's Bay Combined Taxis", w: 300, h: 180 },
];

const faqs = [
  { q: "How many leads will I actually get?", a: "It depends on your trade, your area and your budget, which is exactly what your free audit works out. We give you honest, realistic numbers up front, and report on real calls and quote requests every month." },
  { q: "What if you don't hit my goal?", a: "We keep working and waive our management fee until we do. We agree the target with you before we start, so there are no surprises." },
  { q: "Is there a lock-in contract?", a: "No. You stay because the work keeps coming, not because a contract traps you." },
  { q: "Do I have to pay upfront?", a: `Yes. We take the ${SETUP_FEE} +GST setup and your first month before we start. We're a small Kiwi agency and we don't float thousands of dollars before we've earned your trust. We back it with our 60-day guarantee instead.` },
  { q: "What's included in the monthly price?", a: "Your smart website, our ad management and the automation that turns clicks into booked jobs. Your ad budget is the one thing that's separate, set to suit your goals, so every dollar works for you." },
  { q: "How soon can I start getting leads?", a: "Most campaigns are live within days of your audit, with leads coming in shortly after. We tune everything over the first few weeks to bring your cost per lead down." },
];
---
<Layout>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto grid max-w-[1200px] items-center gap-14 px-5 py-16 sm:py-20 lg:grid-cols-[1.12fr_0.88fr] lg:py-24">
      <div class="min-w-0 text-center lg:text-left">
        <Reveal instant instant>
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/40 bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
            <Icon name="sparkles" class="h-4 w-4" /> NZ's job booking system for tradies
          </span>
        </Reveal>
        <Reveal instant delay={0.05} class="mt-6">
          <h1 class="text-4xl sm:text-6xl xl:text-7xl">
            <span class="block text-[0.66em]">The system that keeps</span>
            <span class="block"><span class="marker rotator" data-rotate>Electricians</span></span>
            <span class="block">booked solid.</span>
          </h1>
        </Reveal>
        <Reveal instant delay={0.1} class="mx-auto mt-6 max-w-xl lg:mx-0">
          <p class="text-lg text-neutral-content/80">
            We find the work, reply to every enquiry in 30 seconds and book jobs straight into your
            calendar while you're flat out on the tools. You just turn up and do the job.
          </p>
        </Reveal>
        <Reveal instant delay={0.15} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row lg:justify-start">
          <a href="#audit" class="btn btn-primary btn-lg btn-shine w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">
            Get my free audit <Icon name="arrow-right" class="h-5 w-5" />
          </a>
          <a href="#how" class="btn btn-outline btn-lg w-full border-white/60 text-white hover:border-white hover:bg-white hover:text-neutral font-display text-lg tracking-wide sm:w-auto">
            See how it works
          </a>
        </Reveal>
        <Reveal instant delay={0.2} class="mt-6 flex justify-center lg:justify-start">
          <SpeedBadge tone="dark" label="Replies in 30 seconds, 24/7" />
        </Reveal>
        <Reveal instant delay={0.26} class="mt-8 flex justify-center lg:justify-start">
          <SocialProof />
        </Reveal>
      </div>

      <Reveal instant delay={0.2} class="relative min-w-0">
        <div class="glow-blob"></div>
        <div class="float-slow relative">
          <LeadFeed />
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ===== TRUST BAR ===== -->
  <div class="border-y border-base-300 bg-base-200">
    <div class="mx-auto flex max-w-[1160px] flex-wrap justify-center gap-x-6 gap-y-6 px-5 py-6 lg:flex-nowrap lg:justify-between">
      {STATS.map((s) => (
        <div class="flex w-full flex-col items-center gap-1 text-center md:w-[30%] md:flex-row md:items-baseline md:justify-center md:gap-2 lg:w-auto">
          <span class="font-display text-4xl text-base-content md:text-3xl">{s.value}</span>
          <span class="text-sm text-base-content/60">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== TRADES MARQUEE ===== -->
  <div class="border-b border-base-300 bg-neutral py-4 text-neutral-content">
    <div class="marquee-wrap">
      <div class="marquee">
        {[...trades, ...trades].map((t) => (
          <span class="mx-7 inline-flex items-center gap-2.5 font-display text-lg font-semibold uppercase tracking-wide text-neutral-content/60">
            <Icon name={t.icon} class="h-5 w-5 text-primary" /> {t.name}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ===== PAIN: THE LEAK ===== -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto grid max-w-[1160px] items-center gap-12 px-5 lg:grid-cols-2">
      <div>
        <Reveal><span class="eyebrow">The leak</span></Reveal>
        <Reveal delay={0.05}>
          <h2 class="mt-3 text-3xl sm:text-5xl">Every missed call is a job for the <span class="highlight">other guy</span>.</h2>
        </Reveal>
        <Reveal delay={0.1}>
          <p class="mt-6 text-lg text-base-content/70">
            You're up a ladder or under a house. The phone rings out. By the time you check it at
            smoko, they've rung the next name on Google and booked him in.
          </p>
        </Reveal>
        <Reveal delay={0.15}>
          <p class="mt-4 text-lg text-base-content/70">It's not your fault. You're busy doing the actual work.</p>
        </Reveal>
        <Reveal delay={0.2}>
          <p class="mt-4 text-lg font-bold text-base-content">But it's quietly costing you real, winnable jobs every single week.</p>
        </Reveal>
      </div>

      <div class="mx-auto w-full max-w-sm space-y-4">
        {missed.map((c, i) => (
          <Reveal delay={0.1 + i * 0.12}>
            <div class={`flex items-center gap-4 rounded-2xl border border-error/20 bg-base-100 p-4 shadow-lg ${c.tilt}`}>
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-error/10 text-error">
                <Icon name={c.icon} class="h-5 w-5" />
              </span>
              <div class="min-w-0">
                <p class="font-display text-lg">{c.title}</p>
                <p class="text-sm text-base-content/60">{c.meta}</p>
              </div>
            </div>
          </Reveal>
        ))}
        <Reveal delay={0.5}>
          <p class="pt-1 text-center text-sm text-base-content/60">
            Three missed calls is a normal morning. Any one of them could've been next week's biggest job.
          </p>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== THE DIFFERENCE ===== -->
  <section class="bg-base-200 py-16 sm:py-24">
    <div class="mx-auto max-w-[1000px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">The difference</span>
        <h2 class="mt-3 text-3xl sm:text-5xl">Two ways to run a trade business.</h2>
      </Reveal>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        <Reveal>
          <div class="card h-full border border-base-300 bg-base-100">
            <div class="card-body">
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-error/10 text-error">
                <Icon name="phone-missed" class="h-5 w-5" />
              </span>
              <h3 class="mt-3 text-2xl">Doing it all yourself</h3>
              <ul class="mt-3 space-y-3 text-base-content/70">
                {alone.map((item) => (
                  <li class="flex gap-3">
                    <Icon name="x" class="mt-1 h-4 w-4 shrink-0 text-error" /> {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </Reveal>
        <Reveal delay={0.08}>
          <div class="card card-glow h-full border-2 border-primary/60 bg-brand-dark text-neutral-content shadow-xl">
            <div class="card-body">
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/15 text-primary">
                <Icon name="bolt" class="h-5 w-5" />
              </span>
              <h3 class="mt-3 text-2xl text-neutral-content">Running the Hyper Digital system</h3>
              <ul class="mt-3 space-y-3 text-neutral-content/80">
                {withUs.map((item) => (
                  <li class="flex gap-3">
                    <Icon name="check" class="mt-1 h-4 w-4 shrink-0 text-primary" /> {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== THE SYSTEM ===== -->
  <section id="how" class="bg-brand-dark scroll-mt-20 text-neutral-content">
    <div class="mx-auto max-w-[1160px] px-5 py-16 sm:py-24">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">The system</span>
        <h2 class="mt-3 text-3xl text-neutral-content sm:text-5xl">One system. Three jobs. All handled.</h2>
        <p class="mt-4 text-neutral-content/70">
          Most agencies sell you one piece of the puzzle and leave you to figure out the rest.
          We build and run the whole machine.
        </p>
      </Reveal>
      <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-3">
        {system.map((c, i) => (
          <Reveal delay={i * 0.08}>
            <div class="card-glow relative h-full overflow-hidden rounded-box border border-white/10 surface-2 p-7">
              <span class="num-ghost absolute -top-3 right-4 text-8xl" aria-hidden="true">{c.n}</span>
              <span class="icon-chip relative">
                <Icon name={c.icon} class="h-6 w-6" />
              </span>
              <h3 class="relative mt-5 text-2xl text-neutral-content">{c.title}</h3>
              <p class="relative mt-2.5 text-neutral-content/70">{c.body}</p>
            </div>
          </Reveal>
        ))}
      </div>
      <Reveal class="mt-12 text-center">
        <a href="#audit" class="btn btn-primary btn-lg font-display text-lg tracking-wide">
          Get my free audit <Icon name="arrow-right" class="h-5 w-5" />
        </a>
      </Reveal>
    </div>
  </section>

  <!-- ===== SPEED WINS ===== -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto grid max-w-[1160px] items-center gap-12 px-5 lg:grid-cols-2">
      <div>
        <Reveal><span class="eyebrow">Speed wins</span></Reveal>
        <Reveal delay={0.05}>
          <h2 class="mt-3 text-3xl sm:text-5xl">The fastest reply wins the job. Yours takes <span class="marker">30 seconds</span>.</h2>
        </Reveal>
        <Reveal delay={0.1}>
          <p class="mt-6 text-lg text-base-content/70">
            Most enquiries sit unanswered for hours. Yours get answered, qualified and booked before
            the customer has finished their cuppa. Day or night, weekends and public holidays, while
            you're on the tools or off the clock.
          </p>
        </Reveal>
        <Reveal delay={0.15} class="mt-8 flex flex-col flex-wrap gap-3 sm:flex-row">
          <a href="#audit" class="btn btn-primary btn-lg font-display text-lg tracking-wide">Get my free audit</a>
          <a href="/ai-automation" class="btn btn-outline btn-lg border-base-content/30 font-display text-lg tracking-wide hover:border-base-content hover:bg-base-content hover:text-base-100">
            See the automation
          </a>
        </Reveal>
      </div>
      <Reveal delay={0.1} class="relative">
        <div class="glow-blob opacity-60"></div>
        <div class="relative"><ChatDemo /></div>
      </Reveal>
    </div>
  </section>

  <!-- ===== PROOF ===== -->
  <section class="bg-base-200 py-16 sm:py-24">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">Proof</span>
        <h2 class="mt-3 text-3xl sm:text-5xl">Real Kiwi businesses. Real numbers.</h2>
      </Reveal>

      <!-- Featured case study -->
      <Reveal class="mt-12">
        <div class="card overflow-hidden border border-base-300 bg-base-100 shadow-md">
          <div class="card-body gap-8 p-7 sm:p-9 lg:flex-row lg:items-center">
            <div class="flex shrink-0 gap-10 lg:flex-col lg:gap-8">
              <div>
                <div class="font-display text-5xl text-primary sm:text-6xl"><span data-count="2500">2,500</span>%</div>
                <div class="mt-1 text-sm text-base-content/60">more enquiries, year one</div>
              </div>
              <div>
                <div class="font-display text-5xl text-primary sm:text-6xl"><span data-count="500">500</span>%</div>
                <div class="mt-1 text-sm text-base-content/60">revenue growth, year one*</div>
              </div>
            </div>
            <div class="min-w-0">
              <Icon name="quote" class="h-8 w-8 text-primary/40" />
              <p class="mt-3 text-xl leading-relaxed text-base-content/80 italic">
                "Month after month, year after year Ryan, Matt and their team at Hyper Digital have
                allowed us the very fortunate position of having new customers booked months in
                advance for our Pools and Spas."
              </p>
              <div class="mt-5 flex items-center gap-3">
                <img src="/img/denise-bermuda-lifestyle-avatar.webp" alt="Denise Howell" width="96" height="96" loading="lazy" decoding="async" class="h-12 w-12 rounded-full object-cover" />
                <div>
                  <div class="font-display text-lg">Denise Howell</div>
                  <div class="text-sm text-base-content/60">Bermuda Lifestyle, Pools &amp; Spas</div>
                </div>
              </div>
              <p class="mt-4 text-xs text-base-content/50">*Revenue growth is client-reported.</p>
            </div>
            <div class="shrink-0 lg:self-center">
              <a href="/results/bermuda-lifestyle" class="btn btn-outline border-primary text-primary hover:bg-primary hover:text-primary-content">
                Read the full story <Icon name="arrow-right" class="h-4 w-4" />
              </a>
            </div>
          </div>
        </div>
      </Reveal>

      <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
        <Reveal>
          <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
            <div class="card-body">
              <div class="flex items-start justify-between">
                <div class="text-primary">★★★★★</div>
                <Icon name="quote" class="h-6 w-6 text-primary/30" />
              </div>
              <p class="text-xl font-bold">Phone enquiries up 69% year-on-year.</p>
              <p class="text-base-content/70 italic">
                "Ryan from Hyper Digital walked through the door and sat with me. He had already
                taken time to learn all about us and what we do. Since then they have got us found
                on Google with Ads to showcase our products all over NZ."
              </p>
              <div class="mt-2 flex items-center gap-3">
                <img src="/img/tableau-towbars-avatar.webp" alt="Tableau Towbars" width="96" height="96" loading="lazy" decoding="async" class="h-11 w-11 rounded-full bg-neutral object-cover" />
                <div class="font-display text-lg">Donna Godfrey, Tableau Towbars</div>
              </div>
            </div>
          </div>
        </Reveal>
        <Reveal delay={0.08}>
          <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
            <div class="card-body">
              <div class="flex items-start justify-between">
                <div class="text-primary">★★★★★</div>
                <Icon name="quote" class="h-6 w-6 text-primary/30" />
              </div>
              <p class="text-xl font-bold">Cost per lead cut from $31 to around $17.</p>
              <p class="text-base-content/70 italic">
                "Harris Pumps and Filtration have been a client of Hyper Digital from the very
                beginning. A great company that has helped grow our online advertising with real
                results. They offer customised solutions that work."
              </p>
              <div class="mt-2 flex items-center gap-3">
                <img src="/img/harris-pumps-avatar.webp" alt="Harris Pumps &amp; Filtration" width="96" height="96" loading="lazy" decoding="async" class="h-11 w-11 rounded-full bg-neutral object-cover" />
                <div class="font-display text-lg">Stephen Harris, Harris Pumps &amp; Filtration</div>
              </div>
            </div>
          </div>
        </Reveal>
      </div>

      <!-- Client logo wall -->
      <Reveal class="mt-14 text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-base-content/50">Some of the businesses we've worked with</p>
        <div class="logo-strip mt-7 flex flex-wrap items-center justify-center gap-x-12 gap-y-7">
          {clientLogos.map((l) =>
            l.darkBox ? (
              <span class="inline-flex items-center bg-neutral px-2 py-1">
                <img src={l.src} alt={l.alt} width={l.w} height={l.h} loading="lazy" decoding="async" class="h-5 w-auto object-contain sm:h-6" />
              </span>
            ) : (
              <img src={l.src} alt={l.alt} width={l.w} height={l.h} loading="lazy" decoding="async" class="h-9 w-auto object-contain sm:h-10" />
            )
          )}
        </div>
        <a href="/results" class="btn btn-ghost mt-8 text-primary">See all case studies <Icon name="arrow-right" class="h-4 w-4" /></a>
      </Reveal>
    </div>
  </section>

  <!-- ===== FOUNDERS ===== -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto grid max-w-[1160px] items-center gap-14 px-5 lg:grid-cols-2">
      <Reveal class="relative mx-auto w-full max-w-lg">
        <div class="absolute -top-4 -left-4 h-full w-full rounded-box border-2 border-primary/40" aria-hidden="true"></div>
        <img
          src="/img/HD-Founders.jpg"
          alt="Matt and Ryan, founders of Hyper Digital"
          width="882"
          height="663"
          loading="lazy"
          decoding="async"
          class="relative w-full rounded-box object-cover shadow-2xl"
        />
        <span class="absolute bottom-4 left-4 inline-flex items-center gap-2 rounded-full bg-neutral/90 px-4 py-1.5 text-sm font-semibold text-neutral-content backdrop-blur">
          <span class="inline-block h-2 w-2 rounded-full bg-primary"></span> Matt &amp; Ryan · Founders
        </span>
      </Reveal>
      <div>
        <Reveal><span class="eyebrow">Who you're dealing with</span></Reveal>
        <Reveal delay={0.05}>
          <h2 class="mt-3 text-3xl sm:text-5xl">Two blokes who answer their own phone.</h2>
        </Reveal>
        <Reveal delay={0.1}>
          <p class="mt-6 text-lg text-base-content/70">
            Hyper Digital is Matt and Ryan. Two hardworking Kiwis who've been running this agency
            since 2019, helping local businesses grow. No account managers, no offshore call centre,
            no runaround. When you ring, you get one of us. And we treat your ad budget like it's
            coming out of our own pocket.
          </p>
        </Reveal>
        <Reveal delay={0.15} class="mt-6 flex flex-wrap gap-2.5">
          <span class="inline-flex items-center gap-2 rounded-full border border-base-300 bg-base-200 px-3.5 py-1.5 text-sm font-semibold"><Icon name="pin" class="h-4 w-4 text-primary" /> Hawke's Bay based, NZ-wide</span>
          <span class="inline-flex items-center gap-2 rounded-full border border-base-300 bg-base-200 px-3.5 py-1.5 text-sm font-semibold"><Icon name="clock" class="h-4 w-4 text-primary" /> Since 2019</span>
          <span class="inline-flex items-center gap-2 rounded-full border border-base-300 bg-base-200 px-3.5 py-1.5 text-sm font-semibold"><Icon name="phone" class="h-4 w-4 text-primary" /> You call, we answer</span>
        </Reveal>
