  <!-- Rotating trade in the hero headline + count-up trust numbers -->
  <script>
    import { animate, inView } from "motion";

    const TRADES = [
      "Electricians", "Plumbers", "Roofers", "Builders",
      "Painters", "Landscapers", "Drainlayers", "Concreters",
    ];

    let rotateTimer: number | undefined;

    function setupRotator() {
      const el = document.querySelector<HTMLElement>("[data-rotate]");
      if (!el) return;
      el.textContent = TRADES[0];

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      let idx = 0;
      clearInterval(rotateTimer);
      rotateTimer = window.setInterval(() => {
        const out = animate(el, { opacity: [1, 0], transform: ["translateY(0px)", "translateY(-14px)"] }, { duration: 0.3, ease: "easeIn" });
        out.finished.then(() => {
          idx = (idx + 1) % TRADES.length;
          el.textContent = TRADES[idx];
          animate(el, { opacity: [0, 1], transform: ["translateY(14px)", "translateY(0px)"] }, { duration: 0.45, ease: [0.16, 1, 0.3, 1] });
        });
      }, 3000);
    }

    // Numbers with [data-count] count up from 0 when scrolled into view.
    // No-JS and reduced-motion users just see the server-rendered final value.
    function setupCounters() {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
        if (el.dataset.counted) return;
        el.dataset.counted = "1";
        const target = parseInt(el.dataset.count || "", 10);
        if (!Number.isFinite(target)) return;
        inView(
          el,
          () => {
            animate(0, target, {
              duration: 1.4,
              ease: [0.16, 1, 0.3, 1],
              onUpdate: (v) => { el.textContent = Math.round(v).toLocaleString("en-NZ"); },
            });
          },
          { amount: 0.6 }
        );
      });
    }

    document.addEventListener("astro:page-load", () => { setupRotator(); setupCounters(); });
    document.addEventListener("astro:before-swap", () => clearInterval(rotateTimer));
  </script>
