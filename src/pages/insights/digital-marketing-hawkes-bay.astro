---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import AuditForm from "../../components/AuditForm.astro";
import SocialProof from "../../components/SocialProof.astro";
import Icon from "../../components/Icon.astro";
import { SITE, STATS } from "../../consts";
import { SETUP_FEE } from "../../data/pricing";

// Local agency page for the "digital marketing hawke's bay / napier / hastings"
// cluster (homepage ranked pos 2-8 for these with ~0 clicks; this page exists to
// win the click). Moved under /insights/ on 11/07/2026 (Matt's call) with a 301 from
// the old path in public/_redirects. Linked from the insights index.
// See ../../../seo/SEO-OPPORTUNITIES-2026-07-03.md.

const title = "Digital Marketing Agency Hawke's Bay | Hyper Digital";
const description =
  "Hyper Digital is a digital marketing agency based in Hawke's Bay since 2019. Google Ads, smart websites, local SEO and AI automation for Napier and Hastings businesses. Free audit.";

const services = [
  { icon: "search", title: "Google Ads", href: "/google-ads", body: "Tightly managed Search campaigns that put you in front of Hawke's Bay locals at the exact moment they need you. Fast results, wasted spend cut, every lead tracked." },
  { icon: "layout", title: "Smart websites", href: "/websites", body: "Fast, search-ready sites that reply to enquiries in 30 seconds, qualify the job and book it in, 24/7. Built to convert, not just to look good." },
  { icon: "pin", title: "Local SEO", href: "/insights/seo-hawkes-bay", body: "Rank in the map pack, local searches and AI answers across Napier and Hastings. The long game that turns paid clicks into free ones." },
  { icon: "cog", title: "AI automation", href: "/ai-automation", body: "Follow-up, review requests and booking on autopilot, so no enquiry slips through the cracks while you're busy working." },
];

const proof = [
  { name: "No Drips, Hawke's Bay plumbers", stat: "$14", statLabel: "cost per lead, best keywords", body: "We took over their Google Ads from another agency, cut close to $3,000 of wasted spend, and now bring in plumbing leads from $14, well under their $45 target.", href: "/results/no-drips" },
  { name: "Hawke's Bay Roofer", stat: "$45k", statLabel: "job from one month of ads", body: "In a single month, $351 of ad spend brought in 18 enquiries, and one became a $45,000 re-roof. High-intent local search, tracked all the way to the won job.", href: "/results/hawkes-bay-roofer" },
  { name: "Continuous Spouting", stat: "$5.87", statLabel: "cost per lead, 4.5 years", body: "Nearly 3,000 enquiries from Hawke's Bay homeowners and builders at under $6 each. One tightly managed campaign, month after month.", href: "/results/continuous-spouting" },
];

const whoFor = [
  "Tradies and home services: our specialty, from plumbers to roofers to sparkies.",
  "Local service businesses that live on Hawke's Bay searches and referrals.",
  "Established businesses whose website or ads have gone stale.",
  "Anyone tired of agencies that report clicks instead of calls.",
];

const faqs = [
  { q: "Are you actually based in Hawke's Bay?", a: "Yes. We live and work in the Bay and have run campaigns for local businesses since 2019. When you call, you get one of the owners, not an account manager three timezones away." },
  { q: "What does it cost?", a: `A one-off ${SETUP_FEE} +GST setup builds your system, then monthly plans start at $497 +GST covering your website, ad management and automation. Ad spend is separate and set to suit your goals. Your free audit tells you the right plan and budget before you commit to anything.` },
  { q: "Do you only work with tradies?", a: "Trades are our specialty and most of our case studies, but the same system works for any local business that wants more calls and bookings. If we don't think we can move the needle for you, we'll say so in the audit." },
  { q: "What makes you different from other Hawke's Bay agencies?", a: "We run the whole pipeline in-house: the ads, the website the ads land on, and the follow-up that books the job. We report on leads and cost per lead, not impressions. And we back it with a 60-day lead guarantee, with no lock-in contracts." },
  { q: "Can you help if my customers are outside Hawke's Bay?", a: "Yes. We're Bay-based but run campaigns NZ-wide, from Auckland to Southland. Local knowledge just means we're extra sharp on Hawke's Bay targeting." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Hyper Digital",
  description: "Digital marketing agency in Hawke's Bay: Google Ads, smart websites, local SEO and AI automation.",
  url: "https://hyperdigital.nz/insights/digital-marketing-hawkes-bay",
  telephone: "+64276661973",
  foundingDate: "2019",
  areaServed: ["Hawke's Bay", "Napier", "Hastings", "Havelock North", "New Zealand"],
  address: { "@type": "PostalAddress", addressRegion: "Hawke's Bay", addressCountry: "NZ" },
  ...(SITE.email ? { email: SITE.email } : {}),
};
---
<Layout title={title} description={description}>
  <!-- ===== HERO (split — service-page template) ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto grid grid-cols-1 max-w-[1160px] items-center gap-12 px-5 py-16 sm:py-24 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="text-center lg:text-left">
        <Reveal instant instant>
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/40 bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
            <Icon name="pin" class="h-4 w-4" /> Hawke's Bay, since 2019
          </span>
        </Reveal>
        <Reveal instant delay={0.05} class="mt-5">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl">
            Digital marketing that gets Hawke's Bay businesses <span class="marker">booked solid</span>.
          </h1>
        </Reveal>
        <Reveal instant delay={0.1} class="mt-6">
          <p class="mx-auto max-w-xl text-lg text-neutral-content/80 lg:mx-0">
            Hyper Digital is a digital marketing agency based right here in the Bay. <a href="/google-ads" class="link text-primary">Google Ads</a>,
            smart websites, local SEO and AI follow-up, run in-house for Napier and Hastings
            businesses. We report on calls and booked jobs, not clicks and impressions.
          </p>
        </Reveal>
        <Reveal instant delay={0.15} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row lg:justify-start">
          <a href="#audit" class="btn btn-primary btn-lg btn-shine w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">
            Get my free audit <Icon name="arrow-right" class="h-5 w-5" />
          </a>
          <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
        </Reveal>
        <Reveal instant delay={0.22} class="mt-9">
          <SocialProof />
        </Reveal>
      </div>

      <!-- Trust stats card -->
      <Reveal instant delay={0.15} class="relative">
        <div class="glow-blob"></div>
        <div class="float-slow relative rounded-box border border-white/10 surface-2 p-6 shadow-xl sm:p-8">
          <span class="eyebrow">Since 2019</span>
          <div class="mt-4 grid grid-cols-2 gap-6">
            {STATS.map((s) => (
              <div>
                <div class="font-display text-3xl text-primary sm:text-4xl">{s.value}</div>
                <div class="mt-1 text-sm text-neutral-content/60">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">What we do</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">One team for the whole pipeline, not one channel.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          Most agencies sell you a channel and leave the rest to you. We run the ads, the website
          the ads land on, and the follow-up that turns an enquiry into a booked job. That's why
          our numbers hold up.
        </p>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 items-stretch gap-6 sm:grid-cols-2">
        {services.map((s, i) => (
          <Reveal delay={i * 0.07} class="h-full">
            <a href={s.href} class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm transition-colors hover:border-primary/50">
              <div class="card-body">
                <span class="icon-chip"><Icon name={s.icon} class="h-6 w-6" /></span>
                <h3 class="mt-3 font-display text-2xl">{s.title}</h3>
                <p class="mt-2 text-base-content/70">{s.body}</p>
                <span class="mt-3 inline-flex items-center gap-2 font-display text-primary">
                  Learn more <Icon name="arrow-right" class="h-4 w-4" />
                </span>
              </div>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== LOCAL PROOF ===== -->
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">Hawke's Bay results</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Local businesses. Real, verifiable numbers.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          These are Hawke's Bay clients, and every number comes from their own accounts. No
          screenshots of someone else's dashboard.
        </p>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
        {proof.map((p, i) => (
          <Reveal delay={i * 0.08}>
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body">
                <div class="font-display text-4xl text-primary">{p.stat}</div>
                <div class="text-sm uppercase tracking-wide text-base-content/60">{p.statLabel}</div>
                <div class="mt-3 font-display text-xl">{p.name}</div>
                <p class="mt-1 text-base-content/70">{p.body}</p>
                <a href={p.href} class="link mt-2 text-primary">Read the case study</a>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
      <Reveal class="mt-10 text-center">
        <a href="/results" class="btn btn-outline border-primary text-primary hover:bg-primary hover:text-primary-content">
          See all results <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </Reveal>
    </div>
  </section>

  <!-- ===== NAPIER & HASTINGS ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">Local knowledge</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Napier and Hastings search differently. We market to both.</h2>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
        <Reveal>
          <div class="h-full rounded-box border border-base-300 bg-base-100 p-6">
            <h3 class="font-display text-2xl">Digital marketing in Napier</h3>
            <p class="mt-2 text-base-content/70">
              Napier customers search "napier" and "near me", and the map pack decides who they
              call. For Napier businesses we tune your Google Business Profile, ads targeting and
              landing pages to the city and its suburbs, from Ahuriri to Taradale, so you show up
              exactly where your customers are looking.
            </p>
          </div>
        </Reveal>
        <Reveal delay={0.08}>
          <div class="h-full rounded-box border border-base-300 bg-base-100 p-6">
            <h3 class="font-display text-2xl">Digital marketing in Hastings</h3>
            <p class="mt-2 text-base-content/70">
              Hastings covers serious ground, from the city out to Havelock North and the rural
              blocks beyond. We build your campaigns around the jobs and areas that actually pay,
              so your budget goes on Hastings customers ready to book, not sightseers three regions
              away.
            </p>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[900px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">Who we work with</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Trades first. Local businesses welcome.</h2>
      </Reveal>
      <Reveal class="mt-8">
        <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {whoFor.map((item) => (
            <li class="flex items-center gap-3 rounded-box border border-base-300 bg-base-100 p-4 transition-colors hover:border-primary/40">
              <span class="icon-chip shrink-0 h-10 w-10"><Icon name="check" class="h-5 w-5" /></span>
              <span class="text-base-content/80">{item}</span>
            </li>
          ))}
        </ul>
      </Reveal>
    </div>
  </section>

  <!-- ===== GUARANTEE ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <div class="relative mx-auto flex h-24 w-24 items-center justify-center">
          <div class="spin-slow absolute inset-0 rounded-full border-2 border-dashed border-primary/50" aria-hidden="true"></div>
          <div class="flex h-[4.3rem] w-[4.3rem] items-center justify-center rounded-full border border-primary/40 bg-primary/15 text-primary">
            <Icon name="shield-check" class="h-9 w-9" />
          </div>
        </div>
        <span class="mt-6 inline-block font-display text-sm font-bold uppercase tracking-[0.2em] text-primary">Our 60-day guarantee</span>
        <h2 class="mt-3 text-3xl text-neutral-content sm:text-5xl">
          Hit your lead goal in 60 days, or we work for <span class="marker">free</span> until you do.
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Before we start, we agree a monthly lead target with you, based on your business, your
          area and your budget. If we don't hit it in the first 60 days, we keep working and waive
          our management fee until we do. You still cover your ad spend, but you won't pay us
          another cent until we deliver.
        </p>
        <a href="#audit" class="btn btn-primary btn-lg mt-8 font-display text-lg tracking-wide">Get my free audit</a>
      </Reveal>
    </div>
  </section>

  <!-- ===== FAQ + AUDIT FORM ===== -->
  <section class="bg-grid-soft border-t border-base-300 py-16 sm:py-20">
    <div class="mx-auto grid grid-cols-1 max-w-[1160px] gap-12 px-5 lg:grid-cols-2 lg:items-start">
      <Reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="mt-3 text-3xl sm:text-4xl">Questions, answered.</h2>
        <div class="mt-6 space-y-3">
          {faqs.map((f) => (
            <div class="collapse collapse-arrow rounded-box border border-base-300 bg-base-100 transition-colors hover:border-primary/40">
              <input type="checkbox" aria-label={f.q} />
              <div class="collapse-title font-display text-xl">{f.q}</div>
              <div class="collapse-content text-base-content/70"><p>{f.a}</p></div>
            </div>
          ))}
        </div>
      </Reveal>
      <Reveal id="audit" delay={0.1} class="scroll-mt-24 lg:sticky lg:top-24">
        <AuditForm
          title="Get your free audit"
          lead="Tell us about your business and we'll show you where your next Hawke's Bay customers are coming from, and what they'll cost."
        />
      </Reveal>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="bg-primary text-primary-content">
    <div class="mx-auto max-w-[820px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <h2 class="text-4xl text-primary-content sm:text-5xl">Ready to be the business that's everywhere?</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-primary-content/80">
          Get your free, no-obligation audit from a local team. We'll show you exactly where your
          next customers are coming from, and what they should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="#audit" class="btn btn-neutral btn-lg btn-shine w-full font-display text-lg tracking-wide shadow-lg sm:w-auto">
            Get my free audit <Icon name="arrow-right" class="h-5 w-5" />
          </a>
          <a href={SITE.phoneHref} class="btn btn-ghost btn-lg w-full font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
        </div>
        <p class="mt-7 text-sm text-primary-content/70">Free 20-minute audit · Hawke's Bay based · No lock-in</p>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />
</Layout>
