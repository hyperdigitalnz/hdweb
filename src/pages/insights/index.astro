---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../consts";

// Insights index. Footer-linked only (nav stays tradie-first). Draft posts are
// excluded here and in [...slug].astro, so a draft never builds anywhere.

const posts = (await getCollection("insights", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Insights | Digital Marketing Guides for NZ Trade Businesses | Hyper Digital";
const description =
  "Straight-talking guides on Google Ads, SEO, websites and lead generation for NZ trade and local businesses. No jargon, no fluff.";

const fmt = (d: Date) =>
  d.toLocaleDateString("en-NZ", { day: "numeric", month: "long", year: "numeric", timeZone: "Pacific/Auckland" });
---
<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1160px] px-5 py-14 text-center sm:py-20">
      <Reveal>
        <span class="eyebrow">Insights</span>
      </Reveal>
      <Reveal delay={0.05} class="mt-3">
        <h1 class="text-4xl sm:text-5xl">Marketing advice that <span class="marker">talks straight</span>.</h1>
      </Reveal>
      <Reveal delay={0.1} class="mt-5">
        <p class="mx-auto max-w-2xl text-lg text-neutral-content/80">
          What we've learned running Google Ads, websites and SEO for Kiwi trade and local
          businesses since 2019. Written so you can actually use it, whether you hire us or not.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== POST LIST ===== -->
  <section class="py-14 sm:py-20">
    <div class="mx-auto max-w-[900px] px-5">
      {posts.length === 0 ? (
        <p class="text-center text-lg text-base-content/70">First articles are on the way.</p>
      ) : (
        <div class="grid grid-cols-1 gap-6">
          {posts.map((post, i) => (
            <Reveal delay={Math.min(i, 4) * 0.06}>
              <a href={`/insights/${post.id}`} class="card card-glow border border-base-300 bg-base-100 shadow-sm transition-colors hover:border-primary/50">
                <div class="card-body">
                  <div class="flex flex-wrap items-center gap-3 text-sm text-base-content/60">
                    <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                    {post.data.tags.map((t) => (
                      <span class="badge badge-outline badge-sm border-primary/40 text-primary">{t}</span>
                    ))}
                  </div>
                  <h2 class="mt-1 font-display text-2xl sm:text-3xl">{post.data.title}</h2>
                  <p class="mt-1 text-base-content/70">{post.data.description}</p>
                  <span class="mt-2 inline-flex items-center gap-2 font-display text-primary">
                    Read article <Icon name="arrow-right" class="h-4 w-4" />
                  </span>
                </div>
              </a>
            </Reveal>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="bg-primary text-primary-content">
    <div class="mx-auto max-w-[820px] px-5 py-14 text-center sm:py-16">
      <Reveal>
        <h2 class="text-3xl text-primary-content sm:text-4xl">Rather have us just handle it?</h2>
        <p class="mx-auto mt-3 max-w-xl text-lg text-primary-content/80">
          Get a free audit and we'll show you where your next jobs are coming from, and what
          they'll cost.
        </p>
        <div class="mt-6 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-neutral btn-lg btn-shine w-full font-display text-lg tracking-wide sm:w-auto">
            Get my free audit <Icon name="arrow-right" class="h-5 w-5" />
          </a>
          <a href={SITE.phoneHref} class="btn btn-ghost btn-lg w-full font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
