---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import AuditForm from "../components/AuditForm.astro";
import SocialProof from "../components/SocialProof.astro";
import SpeedBadge from "../components/SpeedBadge.astro";
import Icon from "../components/Icon.astro";
import { SITE } from "../consts";
import { tradeLeadGen } from "../data/tradeLeadGen";

// Trade-specific landing pages, linked from the "by trade" row below.
const tradePages = Object.values(tradeLeadGen).map((t) => ({
  href: `/${t.slug}`,
  label: t.tradePlural.replace(/^./, (c) => c.toUpperCase()),
}));

const title = "Lead Generation for Tradies | More Calls & Booked Jobs | Hyper Digital";
const description =
  "We get Kiwi tradies more calls and quote requests: Google Ads for fast results, local SEO built in, Meta when it's worth it. More leads on the same budget. Free audit.";

const channels = [
  {
    icon: "search",
    tag: "Our usual starting point",
    title: "Google Ads",
    body: "The fastest way to get leads. When someone searches for your trade in your area, we put you in front of them at the exact moment they need you. You're paying to reach people ready to book right now, which is why we usually start here. You can see results in days, not months.",
    popular: true,
  },
  {
    icon: "pin",
    tag: "Built into your website",
    title: "Local SEO & AEO",
    body: "Every website we build is set up to rank in local Google searches, the map pack and AI answers from day one. It takes longer than ads, but it builds free traffic that compounds over time. Ads get you leads today; SEO keeps them coming without paying for every click.",
    popular: false,
  },
  {
    icon: "megaphone",
    tag: "When it's worth it",
    title: "Meta (Facebook & Instagram)",
    body: "Facebook and Instagram can work well for some trades, but usually only once your Google spend is big enough to justify it. We won't push you onto Meta just to pad an invoice. When the numbers say it's time, we'll tell you.",
    popular: false,
  },
];

const levers = [
  { icon: "target", title: "Tightly targeted campaigns", body: "Built around your real services and the exact areas you cover, no spray and pray." },
  { icon: "search", title: "Wasted spend cut", body: "We strip out the junk searches that quietly drain most tradie accounts." },
  { icon: "layout", title: "Dedicated landing pages", body: "Your ads point to pages built to convert, not a generic homepage." },
  { icon: "phone", title: "Every call & form tracked", body: "We measure real leads, so we know exactly what's working and what to sharpen." },
];

const getList = [
  "Leads mean phone calls and quote requests, not clicks or impressions.",
  "Run in-house by our team, never farmed out offshore.",
  "Honest monthly reporting on real outcomes and your cost per lead.",
  "No lock-in contract. You stay because it works.",
];

const proof = [
  { name: "Tableau Towbars", stat: "+69%", statLabel: "phone enquiries YoY", body: "Tracked enquiries up 12% on flat ad spend with cost per lead down 11%. A 4½-year partnership and counting." },
  { name: "Harris Pumps & Filtration", stat: "$31 → $17", statLabel: "cost per lead", body: "29% more leads in 2025 than 2024 while cutting cost per lead by nearly a quarter." },
  { name: "Bermuda Lifestyle", stat: "+2,500%", statLabel: "enquiries in year one", body: "A brand-new website plus Google, Facebook and Instagram working together." },
];

const faqs = [
  { q: "Which channel is right for my trade?", a: "That's exactly what your free audit works out. For most trades we start with Google Ads for fast results and build local SEO into your website for the long game. We add Meta only when your spend justifies it." },
  { q: "How is this different from a normal Google Ads agency?", a: "Most agencies sell you one channel and leave the rest to you. We run the whole pipeline, from ads to website to follow-up, so the leads we generate actually turn into booked jobs. And we back it with a 60-day lead guarantee." },
  { q: "How soon will I see leads?", a: "Most Google Ads campaigns are live within days of your audit, with leads coming in shortly after. SEO builds over the following months on top of that." },
  { q: "Will you lock me into a contract?", a: "No. You stay because the work keeps coming, not because a contract traps you." },
  { q: "What counts as a lead?", a: "A real phone call or quote request from a potential customer, not clicks or impressions." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<Layout title={title} description={description}>
  <!-- ===== HERO (split — service-page template) ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto grid max-w-[1160px] items-center gap-12 px-5 py-16 sm:py-24 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="text-center lg:text-left">
        <Reveal>
          <span class="eyebrow">Find the work</span>
        </Reveal>
        <Reveal delay={0.05} class="mt-3">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl">
            Lead generation for tradies that <span class="marker">fills your calendar</span>.
          </h1>
        </Reveal>
        <Reveal delay={0.1} class="mt-6">
          <p class="mx-auto max-w-xl text-lg text-neutral-content/80 lg:mx-0">
            We bring ready-to-buy local customers to your business on the channel that works best
            for your trade. Usually a tight Google Ads campaign for fast results, backed by local
            SEO that keeps working for free. Real calls and quote requests, not vanity clicks.
          </p>
        </Reveal>
        <Reveal delay={0.15} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row lg:justify-start">
          <a href="#audit" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">Get my free audit</a>
          <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
        </Reveal>
        <Reveal delay={0.2} class="mt-6 flex justify-center lg:justify-start">
          <SpeedBadge tone="dark" label="Replies in 30 seconds, 24/7" />
        </Reveal>
        <Reveal delay={0.26} class="mt-9">
          <SocialProof />
        </Reveal>
      </div>
      <Reveal delay={0.15}>
        <img src="/pipeline-animation.gif" alt="How Hyper Digital turns local searches into booked jobs" class="w-full rounded-box shadow-2xl" />
      </Reveal>
    </div>
  </section>

  <!-- ===== BEST TOOL FOR THE JOB (icon cards) ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-3xl text-center">
        <span class="eyebrow">The best tool for the job</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">
          We use the channel that gets you leads, not the one we feel like selling.
        </h2>
        <p class="mt-4 text-lg text-base-content/70">
          You don't care whether a lead comes from Google, Facebook or a top spot on the map. You
          just want the phone to ring. So we pick the mix that gets the best results for your trade
          and budget, and we're straight with you about why.
        </p>
      </Reveal>

      <div class="mt-10 grid items-stretch gap-6 md:grid-cols-3">
        {channels.map((c, i) => (
          <Reveal delay={i * 0.08} class="h-full">
            <div class={`card h-full border bg-base-100 shadow-sm ${c.popular ? "border-primary card-glow shadow-md" : "border-base-300"}`}>
              <div class="card-body">
                <span class="icon-chip"><Icon name={c.icon} class="h-6 w-6" /></span>
                <span class={`badge mt-3 self-start font-display ${c.popular ? "badge-primary" : "badge-outline border-primary/40 text-primary"}`}>{c.tag}</span>
                <h3 class="mt-1 font-display text-2xl">{c.title}</h3>
                <p class="mt-2 text-base-content/70">{c.body}</p>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW WE RUN CAMPAIGNS (animated chart + icon levers) ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">How we run your campaigns</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">How we get your cost per lead down.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          We don't set and forget. Every month we sharpen four things, and that's how Harris Pumps
          went from $31 a lead to around $17.
        </p>
      </Reveal>

      <div class="mt-12 grid items-center gap-10 lg:grid-cols-2">
        <!-- Animated cost-per-lead chart (moving part) -->
        <Reveal>
          <div class="rounded-box border border-base-300 surface-2 p-6 text-neutral-content shadow-xl sm:p-8">
            <div class="flex items-center justify-between">
              <span class="eyebrow">Cost per lead</span>
              <span class="badge badge-primary font-display">↓ 45%</span>
            </div>
            <svg viewBox="0 0 320 170" class="mt-4 w-full" role="img" aria-label="Cost per lead falling from $31 to around $17 over time">
              <!-- baseline grid -->
              <g stroke="rgba(255,255,255,0.08)" stroke-width="1">
                <line x1="10" y1="20" x2="310" y2="20" />
                <line x1="10" y1="60" x2="310" y2="60" />
                <line x1="10" y1="100" x2="310" y2="100" />
                <line x1="10" y1="140" x2="310" y2="140" />
              </g>
              <!-- the declining line -->
              <path
                class="draw-line"
                style="--len: 360"
                d="M14 34 L74 58 L134 50 L194 92 L254 112 L306 130"
                fill="none"
                stroke="var(--color-primary)"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <!-- endpoint markers -->
              <circle cx="14" cy="34" r="4" fill="var(--color-primary)" />
              <circle class="fade-in-late" cx="306" cy="130" r="5" fill="var(--color-primary)" />
              <!-- labels -->
              <text x="14" y="24" fill="#faf8f5" font-size="15" font-weight="800" font-family="Source Sans 3">$31</text>
              <text class="fade-in-late" x="288" y="124" fill="var(--color-primary)" font-size="15" font-weight="800" font-family="Source Sans 3">$17</text>
            </svg>
            <p class="mt-3 text-sm text-neutral-content/60">
              Real client trend, Harris Pumps &amp; Filtration. Illustrative chart.
            </p>
          </div>
        </Reveal>

        <!-- The four levers -->
        <div class="grid gap-4 sm:grid-cols-2">
          {levers.map((l, i) => (
            <Reveal delay={i * 0.07}>
              <div class="flex h-full gap-4 rounded-box border border-base-300 bg-base-100 p-5">
                <span class="icon-chip shrink-0"><Icon name={l.icon} class="h-6 w-6" /></span>
                <div>
                  <h3 class="font-display text-lg">{l.title}</h3>
                  <p class="mt-1 text-sm text-base-content/70">{l.body}</p>
                </div>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT YOU GET (icon checklist) ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[900px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">What you actually get</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Real leads. Managed in-house. No lock-in.</h2>
      </Reveal>
      <Reveal class="mt-8">
        <ul class="grid gap-3 sm:grid-cols-2">
          {getList.map((item) => (
            <li class="flex items-center gap-3 rounded-box border border-base-300 bg-base-100 p-4">
              <span class="icon-chip shrink-0 h-10 w-10"><Icon name="check" class="h-5 w-5" /></span>
              <span class="text-base-content/80">{item}</span>
            </li>
          ))}
        </ul>
      </Reveal>
    </div>
  </section>

  <!-- ===== PROOF (stat tiles + logo strip) ===== -->
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">Proof</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">More leads on the same budget. That's the whole point.</h2>
      </Reveal>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {proof.map((p, i) => (
          <Reveal delay={i * 0.08}>
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body">
                <div class="font-display text-4xl text-primary">{p.stat}</div>
                <div class="text-sm uppercase tracking-wide text-base-content/60">{p.statLabel}</div>
                <div class="mt-3 font-display text-xl">{p.name}</div>
                <p class="mt-1 text-base-content/70">{p.body}</p>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
      <Reveal class="mt-10 text-center">
        <a href="/results" class="btn btn-outline border-primary text-primary hover:bg-primary hover:text-primary-content">See more results →</a>
      </Reveal>
    </div>
  </section>

  <!-- ===== PRICING ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[1000px] px-5">
      <Reveal class="text-center">
        <span class="eyebrow">Pricing</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Simple plans. No lock-in.</h2>
      </Reveal>

      <div class="mt-10 grid items-stretch gap-6 md:grid-cols-2">
        <Reveal class="h-full">
          <div class="card h-full border border-base-300 bg-base-100 shadow-sm">
            <div class="card-body">
              <span class="icon-chip"><Icon name="bolt" class="h-6 w-6" /></span>
              <div class="mt-3 text-sm uppercase tracking-wide text-base-content/60">One-off setup</div>
              <div class="font-display text-4xl text-primary">$1,997 <span class="text-2xl text-base-content/60">+GST</span></div>
              <p class="mt-2 text-base-content/70">Gets your whole system built and live, ready to start bringing in leads.</p>
            </div>
          </div>
        </Reveal>
        <Reveal delay={0.08} class="h-full">
          <div class="card card-glow h-full border border-primary bg-base-100 shadow-md">
            <div class="card-body">
              <span class="icon-chip"><Icon name="calendar" class="h-6 w-6" /></span>
              <div class="mt-3 text-sm uppercase tracking-wide text-base-content/60">Then, monthly</div>
              <div class="font-display text-4xl text-primary">From $497 <span class="text-2xl text-base-content/60">/mo +GST</span></div>
              <p class="mt-2 text-base-content/70">Website, ad management and automation. Your ad budget is separate and set to suit your goals.</p>
            </div>
          </div>
        </Reveal>
      </div>

      <Reveal class="mt-6">
        <p class="mx-auto max-w-2xl text-center text-base-content/70">
          Your free audit tells you the right plan and budget for your trade and area. No guesswork,
          no hidden extras.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== GUARANTEE ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="shield" class="h-7 w-7" /></span>
        <h2 class="mt-5 text-3xl text-neutral-content sm:text-5xl">
          Hit your lead goal in 60 days, or we work for <span class="text-primary">free</span> until you do.
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Before we start, we agree a monthly lead target with you, based on your trade, your area
          and your budget. If we don't hit it in the first 60 days, we keep working and waive our
          management fee until we do. You still cover your ad spend, but you won't pay us another
          cent until we deliver.
        </p>
        <a href="#audit" class="btn btn-primary mt-7 font-display text-lg tracking-wide">Get my free audit</a>
      </Reveal>
    </div>
  </section>

  <!-- ===== FAQ + AUDIT FORM ===== -->
  <section id="audit" class="scroll-mt-24 bg-grid-soft border-t border-base-300 py-16 sm:py-20">
    <div class="mx-auto grid max-w-[1160px] gap-12 px-5 lg:grid-cols-2 lg:items-start">
      <Reveal>
        <h2 class="text-3xl sm:text-4xl">Questions, answered.</h2>
        <div class="mt-6 space-y-3">
          {faqs.map((f) => (
            <div class="collapse collapse-arrow border border-base-300 bg-base-100">
              <input type="checkbox" />
              <div class="collapse-title font-display text-xl">{f.q}</div>
              <div class="collapse-content text-base-content/70"><p>{f.a}</p></div>
            </div>
          ))}
        </div>
      </Reveal>
      <Reveal delay={0.1} class="lg:sticky lg:top-24">
        <AuditForm title="Get your free audit" lead="In 20 minutes we'll show you which channels will work best for your trade, and what your leads should cost." />
      </Reveal>
    </div>
  </section>

  <!-- ===== LEAD GENERATION BY TRADE ===== -->
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[1000px] px-5 text-center">
      <Reveal>
        <span class="eyebrow">By trade</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Built for your trade.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-base-content/70">
          Every trade gets found differently. See how the system works for yours, with the searches,
          jobs and numbers specific to your work.
        </p>
      </Reveal>
      <Reveal class="mt-8">
        <div class="flex flex-wrap justify-center gap-3">
          {tradePages.map((t) => (
            <a href={t.href} class="btn btn-outline border-primary text-primary hover:bg-primary hover:text-primary-content font-display">
              {t.label} →
            </a>
          ))}
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="bg-primary text-primary-content">
    <div class="mx-auto max-w-[820px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <h2 class="text-4xl text-primary-content sm:text-5xl">Want more booked jobs from the same budget?</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-primary-content/80">
          Get your free, no-obligation audit. We'll show you which channels will work best for your
          trade and what your leads should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="#audit" class="btn btn-neutral btn-lg w-full font-display text-lg tracking-wide shadow-lg sm:w-auto">Get my free audit</a>
          <a href={SITE.phoneHref} class="btn btn-ghost btn-lg w-full font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
</Layout>
