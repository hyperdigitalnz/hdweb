---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import { SITE } from "../consts";

// Links-in-bio page for the social profiles (@hyperdigitalnz everywhere), at the exact
// URL the bios use: /links-in-bio. Chrome-free (no header/footer/chat), noindex and out
// of the sitemap: it exists for humans tapping a bio link, not for Google. Common bio
// slugs (/links, /bio, /linkinbio, …) 301 here.

const title = "Links | Hyper Digital";
const description =
  "All the Hyper Digital links in one place: website, Facebook, Instagram and X.";

// Brand glyphs inline (Icon.astro holds stroke icons; FB/X are filled marks).
const icons: Record<string, string> = {
  globe:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>',
  facebook:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6"><path d="M13.5 21.5v-7.4h2.5l.47-3.1H13.5V9.03c0-.85.28-1.6 1.6-1.6h1.5V4.64c-.27-.04-1.2-.14-2.28-.14-2.32 0-3.82 1.41-3.82 3.99V11H8v3.1h2.5v7.4h3z"/></svg>',
  instagram:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.3" cy="6.7" r="0.5" fill="currentColor"/></svg>',
  x:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6"><path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.21-6.82-5.97 6.82H1.67l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.08 4.13H5.12l11.96 15.64z"/></svg>',
};

const links = [
  { icon: "globe", label: "Visit our website", sub: "hyperdigital.nz", href: "/", external: false },
  { icon: "facebook", label: "Facebook", sub: "@hyperdigitalnz", href: "https://www.facebook.com/hyperdigitalnz/", external: true },
  { icon: "instagram", label: "Instagram", sub: "@hyperdigitalnz", href: "https://www.instagram.com/hyperdigitalnz/", external: true },
  { icon: "x", label: "X", sub: "@HyperDigitalnz", href: "https://x.com/HyperDigitalnz", external: true },
];
---
<Layout title={title} description={description} noindex hideHeader hideFooter hideChat>
  <section class="bg-brand-dark flex min-h-svh items-center text-neutral-content">
    <div class="mx-auto w-full max-w-[420px] px-5 py-14 text-center">
      <Reveal>
        <span class="mx-auto flex h-24 w-24 items-center justify-center rounded-full border-2 border-primary/50 bg-primary/10 p-2 shadow-lg shadow-primary/20">
          <img src="/img/hd-favicon.png" alt="Hyper Digital brand mark" width="96" height="96" class="h-16 w-16 object-contain" />
        </span>
      </Reveal>
      <Reveal delay={0.05} class="mt-5">
        <h1 class="logo text-3xl">HYPER<span class="text-primary">DIGITAL</span></h1>
      </Reveal>
      <Reveal delay={0.1} class="mt-2">
        <p class="text-neutral-content/70">
          More calls, booked jobs and 5-star reviews for Kiwi trade and local businesses.
        </p>
      </Reveal>

      <Reveal delay={0.15} class="mt-8">
        <div class="grid gap-3">
          {links.map((l) => (
            <a
              href={l.href}
              target={l.external ? "_blank" : undefined}
              rel={l.external ? "noopener" : undefined}
              class="group flex items-center gap-4 rounded-box border border-white/10 bg-white/5 p-4 text-left transition-all hover:scale-[1.02] hover:border-primary/60 hover:bg-primary/10"
            >
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary" set:html={icons[l.icon]} />
              <span class="min-w-0">
                <span class="block font-display text-lg leading-tight">{l.label}</span>
                <span class="block truncate text-sm text-neutral-content/60">{l.sub}</span>
              </span>
              <span class="ml-auto text-primary opacity-0 transition-opacity group-hover:opacity-100" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </Reveal>

      <Reveal delay={0.25} class="mt-8">
        <p class="text-sm text-neutral-content/50">
          {SITE.name} · Hawke's Bay, NZ · <a href={SITE.phoneHref} class="transition-colors hover:text-primary">{SITE.phone}</a>
        </p>
      </Reveal>
    </div>
  </section>
</Layout>
