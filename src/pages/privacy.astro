---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../consts";

const title = "Privacy Policy | Hyper Digital";
const description =
  "How Hyper Digital collects, uses and shares the information you provide when using our services.";

const collect = [
  "Direct submissions: your name, contact details and payment information.",
  "Automatic collection: device information, service usage patterns and IP addresses.",
  "Third-party sources: social media platforms and partner organisations.",
];

const uses = [
  "Providing, maintaining and improving our services.",
  "Account and service communications.",
  "Personalising your experience.",
  "Analysing usage trends.",
  "Preventing fraud and unlawful activity.",
  "Meeting our legal obligations.",
  "General business operations.",
];

const sharing = [
  "With your explicit consent.",
  "With service providers, such as payment processors and hosting companies.",
  "For legal compliance or fraud investigation.",
  "During a company sale or merger.",
];

const rights = [
  "Request access to the information we hold about you.",
  "Request corrections to inaccurate data.",
  "Request deletion of your information.",
  "Opt out of marketing communications.",
  "Exercise these rights using the contact methods below.",
];
---
<Layout title={title} description={description}>
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[820px] px-5 py-16 text-center sm:py-20">
      <span class="eyebrow">Legal</span>
      <h1 class="mt-3 text-4xl sm:text-5xl">Privacy <span class="marker">policy</span>.</h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-neutral-content/80">
        Your details are yours. Here is what we collect, how we use it, and who we share it with.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[760px] px-5">
      <p class="text-base-content/80">
        Hyper Digital ("we", "us" or "our") is committed to protecting the privacy of our clients
        and website users. This policy explains how information is collected, used and shared when
        you access our services. By using our services, you agree to this policy.
      </p>

      <h2 class="mt-10 font-display text-2xl">Information we collect</h2>
      <p class="mt-2 text-base-content/80">We gather data through several methods:</p>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-base-content/80">
        {collect.map((c) => <li>{c}</li>)}
      </ul>

      <h2 class="mt-10 font-display text-2xl">How we use your information</h2>
      <p class="mt-2 text-base-content/80">The data we collect supports these purposes:</p>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-base-content/80">
        {uses.map((u) => <li>{u}</li>)}
      </ul>

      <h2 class="mt-10 font-display text-2xl">Sharing your information</h2>
      <p class="mt-2 text-base-content/80">We share information only under these conditions:</p>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-base-content/80">
        {sharing.map((s) => <li>{s}</li>)}
      </ul>

      <h2 class="mt-10 font-display text-2xl">Your choices and rights</h2>
      <p class="mt-2 text-base-content/80">You may:</p>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-base-content/80">
        {rights.map((r) => <li>{r}</li>)}
      </ul>

      <h2 class="mt-10 font-display text-2xl">Changes to this policy</h2>
      <p class="mt-2 text-base-content/80">
        We may update this policy from time to time to reflect changes in our practices or
        regulatory requirements. Please review it periodically. The latest version will always be on
        this page.
      </p>

      <h2 class="mt-10 font-display text-2xl">Contact us</h2>
      <div class="mt-2 rounded-box border border-base-300 bg-base-200 p-6">
        <p class="font-display text-lg">Hyper Digital</p>
        <p class="text-base-content/80">Napier, Hawke's Bay</p>
        <p class="mt-2 text-base-content/80">
          Phone: <a class="font-semibold text-primary" href={SITE.phoneHref}>{SITE.phone}</a>
        </p>
        {SITE.email && (
          <p class="text-base-content/80">
            Email: <a class="font-semibold text-primary" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </p>
        )}
      </div>
    </div>
  </section>
</Layout>
