---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../consts";

const title = "Continuous Spouting Case Study | Spouting & Guttering Leads | Hyper Digital";
const description =
  "How one tightly managed Google Ads campaign delivers leads at under $6 each for Continuous Spouting in Hawke's Bay, with a click-through rate three to five times the industry average.";

const client = "Continuous Spouting";
const trade = "Spouting & Guttering";
const region = "Hawke's Bay";

// ── At-a-glance (rates and unit cost only — no volumes) ─────────────────────
const glance = [
  { value: "5.87", prefix: "$", suffix: "", decimals: 2, label: "average cost per lead" },
  { value: "15.5", prefix: "", suffix: "%", decimals: 1, label: "click-through rate" },
  { value: "5", prefix: "", suffix: "x", decimals: 0, label: "up to, vs the industry average" },
  { value: "4.5", prefix: "", suffix: " yrs", decimals: 1, label: "partnership and counting" },
];

// ── What we did ─────────────────────────────────────────────────────────────
const work = [
  { icon: "search", title: "One focused Search campaign", body: "A single, tightly managed Google Ads campaign for Hawke's Bay. No sprawling setup to maintain, just one campaign kept razor sharp." },
  { icon: "target", title: "Ongoing keyword refinement", body: "We keep the keywords matched to real buyer searches for spouting, fascia and downpipe work, and prune anything that drifts off intent." },
  { icon: "megaphone", title: "Ad copy that matches intent", body: "Ads written to speak directly to what the searcher needs, which is exactly why the click-through rate sits so far above average." },
  { icon: "trend", title: "Consistency, month after month", body: "Leads arrive at a predictable cost, giving the business a pipeline it can actually plan around." },
];

// ── What stands out (rates and unit cost only) ──────────────────────────────
const standout = [
  "Cost per lead under $6, for jobs often worth well over a thousand dollars.",
  "Click-through rate peaked above 32% in a single month and regularly sits between 15% and 25%.",
  "Cost per lead has held steady at around $6 for three years running.",
  "One campaign, done well. The client keeps growing their investment as leads convert to jobs.",
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Results", item: "https://hyperdigital.nz/results" },
    { "@type": "ListItem", position: 2, name: `${client} case study`, item: "https://hyperdigital.nz/results/continuous-spouting" },
  ],
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${client} case study: leads at under $6 each`,
  about: trade,
  author: { "@type": "Organization", name: "Hyper Digital" },
  publisher: { "@type": "Organization", name: "Hyper Digital" },
  description,
};
---
<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1160px] px-5 py-14 sm:py-20">
      <Reveal instant instant>
        <nav class="text-sm text-neutral-content/60" aria-label="Breadcrumb">
          <a href="/results" class="transition-colors hover:text-primary">Results</a>
          <span class="px-2">/</span>
          <span class="text-neutral-content/90">{client}</span>
        </nav>
      </Reveal>
      <div class="mt-8 grid grid-cols-1 items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="text-center lg:text-left">
          <Reveal instant instant>
            <span class="badge badge-primary font-display">Case study · {trade}</span>
          </Reveal>
          <Reveal instant delay={0.05} class="mt-4">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl">
              Quality leads at <span class="marker">under $6 each</span>.
            </h1>
          </Reveal>
          <Reveal instant delay={0.1} class="mt-5">
            <p class="text-sm uppercase tracking-wider text-primary">{region}</p>
          </Reveal>
          <Reveal instant delay={0.14} class="mt-5">
            <p class="mx-auto max-w-xl text-lg text-neutral-content/80 lg:mx-0">
              A 4.5-year partnership built on a single, tightly managed Google Ads Search campaign.
              We put Continuous Spouting in front of Hawke's Bay homeowners and builders the moment
              they search for spouting and guttering. No complicated setup. Just consistent, efficient leads.
            </p>
          </Reveal>
          <Reveal instant delay={0.2} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row lg:justify-start">
            <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">Get my free audit</a>
            <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
          </Reveal>
        </div>

        <!-- Hero media — client website -->
        <Reveal instant delay={0.15}>
          <img
            src="/img/case-studies/continuous-spouting/bevelled-rakes-continuous-spouting.webp"
            alt="Bevelled rakes continuous spouting on a Hawke's Bay home"
            loading="eager"
            class="aspect-[4/3] w-full rounded-box border border-base-300 object-cover shadow-xl"
          />
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== AT A GLANCE (count-up) ===== -->
  <section class="border-b border-base-300 bg-base-100 py-10 sm:py-12">
    <div class="mx-auto max-w-[1160px] px-5">
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {glance.map((g) => (
          <div class="text-center">
            <div
              class="font-display text-3xl text-primary sm:text-4xl"
              data-countup={g.value}
              data-prefix={g.prefix}
              data-suffix={g.suffix}
              data-decimals={g.decimals}
            >{g.prefix}{g.value}{g.suffix}</div>
            <div class="mt-1 text-sm text-base-content/60">{g.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE CHALLENGE ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="target" class="h-7 w-7" /></span>
        <span class="eyebrow mt-5 block">The challenge</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Keep the phone ringing in a busy local trade.</h2>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="text-lg text-base-content/70">
          Continuous Spouting needed a reliable way to keep homeowners and builders calling for
          spouting, fascia and downpipe work in Hawke's Bay. Like most trades, the battle is being
          found at the right moment in a competitive local market, without burning budget on the
          wrong searches. They needed a pipeline they could count on, not a lucky month here and there.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== WHAT WE DID ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">What we did</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Find: one campaign, done exceptionally well.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          No complex machine to maintain. Just a single Search campaign, kept sharp every month,
          aimed squarely at people in Hawke's Bay ready to book.
        </p>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {work.map((w, i) => (
          <Reveal delay={i * 0.07} class="h-full">
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body flex-row gap-4">
                <span class="icon-chip shrink-0"><Icon name={w.icon} class="h-6 w-6" /></span>
                <div>
                  <h3 class="font-display text-xl">{w.title}</h3>
                  <p class="mt-1 text-base-content/70">{w.body}</p>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE RESULTS (interactive CTR comparison + bullets) ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">The results</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Ads people actually click, leads that actually cost less.</h2>
      </Reveal>

      <div class="mt-12 grid grid-cols-1 items-center gap-10 lg:grid-cols-2">
        <!-- Interactive CTR comparison -->
        <Reveal>
          <div data-cmp data-max="18" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm sm:p-8">
            <div class="flex items-center justify-between">
              <span class="eyebrow">Click-through rate</span>
              <span data-cmp-value class="badge badge-primary font-display">15.5%</span>
            </div>
            <div class="mt-5 h-9 w-full overflow-hidden rounded-full bg-base-200">
              <div class="cmp-fill"></div>
            </div>
            <div class="mt-6 flex flex-wrap gap-1 rounded-box border border-base-300 bg-base-100 p-1" role="tablist" aria-label="Compare click-through rate">
              <button type="button" role="tab" class="tab-btn" data-val="4" data-display="3-5%" aria-selected="false">Typical Search ad</button>
              <button type="button" role="tab" class="tab-btn is-active" data-val="15.5" data-display="15.5%" aria-selected="true">Continuous Spouting</button>
            </div>
            <p class="mt-3 text-sm text-base-content/55">
              Industry average for Search ads is 3 to 5%. Tap to compare. The higher the click-through rate, the more relevant the ad and the lower the cost per lead.
            </p>
          </div>
        </Reveal>

        <!-- What stands out -->
        <div>
          <Reveal><h3 class="font-display text-2xl">What stands out</h3></Reveal>
          <ul class="mt-5 space-y-3">
            {standout.map((s, i) => (
              <Reveal delay={i * 0.06}>
                <li class="flex items-start gap-3 rounded-box border border-base-300 bg-base-100 p-4">
                  <span class="icon-chip shrink-0 h-10 w-10"><Icon name="check" class="h-5 w-5" /></span>
                  <span class="text-base-content/80">{s}</span>
                </li>
              </Reveal>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COST PER LEAD, STEADY (animated near-flat line) ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1000px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="eyebrow">The number that matters</span>
        <h2 class="mt-2 text-3xl text-neutral-content sm:text-4xl">Cost per lead, around $6, year after year.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-neutral-content/80">
          What tracks as a conversion has changed over the years, so we don't lean on lead counts.
          The figure we stand behind is the cost of each lead, and it has barely moved.
        </p>
      </Reveal>
      <Reveal class="mt-10">
        <svg viewBox="0 0 600 150" class="w-full" role="img" aria-label="Cost per lead holding steady at around six dollars over several years">
          <g stroke="rgba(255,255,255,0.08)" stroke-width="1">
            <line x1="10" y1="40" x2="590" y2="40" />
            <line x1="10" y1="80" x2="590" y2="80" />
            <line x1="10" y1="120" x2="590" y2="120" />
          </g>
          <path class="draw-line" style="--len: 600" d="M20 86 L160 80 L300 84 L440 79 L580 82" fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="20" cy="86" r="4" fill="var(--color-primary)" />
          <circle cx="160" cy="80" r="4" fill="var(--color-primary)" />
          <circle cx="300" cy="84" r="4" fill="var(--color-primary)" />
          <circle cx="440" cy="79" r="4" fill="var(--color-primary)" />
          <circle class="fade-in-late" cx="580" cy="82" r="5" fill="var(--color-primary)" />
          <text class="fade-in-late" x="500" y="68" fill="var(--color-primary)" font-size="16" font-weight="800" font-family="Source Sans 3">~ $6 / lead</text>
        </svg>
        <p class="mt-3 text-sm text-neutral-content/55">Direction of tracked cost per lead across the partnership. Illustrative.</p>
      </Reveal>
    </div>
  </section>

  <!-- ===== TESTIMONIAL (slot ready — add a verified quote here) ===== -->
  <!--
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <div class="text-2xl text-primary">★★★★★</div>
      <blockquote class="mt-4 font-display text-2xl leading-snug sm:text-3xl">"[Add a verified Google review or client quote here.]"</blockquote>
      <div class="mt-4 font-display text-base-content/70">Owner name, Continuous Spouting</div>
    </div>
  </section>
  -->

  <!-- ===== CTA ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="shield" class="h-7 w-7" /></span>
        <h2 class="mt-5 text-3xl text-neutral-content sm:text-5xl">Want results like these for your business?</h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Hit your agreed lead goal in 60 days, or we work for free until you do. Get a free, no-obligation
          audit and we'll show you what your leads should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Get my free audit</a>
          <a href="/results" class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">See more results</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify([breadcrumbSchema, articleSchema])} />

  <!-- Interactive behaviour: comparison toggle + count-up -->
  <script>
    import { inView } from "motion";

    function setupCompare() {
      document.querySelectorAll<HTMLElement>("[data-cmp]").forEach((c) => {
        if (c.dataset.bound) return;
        c.dataset.bound = "1";
        const fill = c.querySelector<HTMLElement>(".cmp-fill");
        const out = c.querySelector<HTMLElement>("[data-cmp-value]");
        const max = parseFloat(c.dataset.max || "18");
        const buttons = c.querySelectorAll<HTMLButtonElement>(".tab-btn");
        const apply = (btn: HTMLButtonElement) => {
          const val = parseFloat(btn.dataset.val || "0");
          buttons.forEach((b) => {
            const active = b === btn;
            b.classList.toggle("is-active", active);
            b.setAttribute("aria-selected", active ? "true" : "false");
          });
          if (fill) fill.style.width = Math.min(100, (val / max) * 100) + "%";
          if (out) out.textContent = btn.dataset.display || "";
        };
        buttons.forEach((b) => b.addEventListener("click", () => apply(b)));
        const init = c.querySelector<HTMLButtonElement>(".tab-btn.is-active") || buttons[0];
        if (init) apply(init);
      });
    }

    function setupCountUp() {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => {
        if (el.dataset.counted) return;
        const target = parseFloat(el.dataset.countup || "0");
        const decimals = parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const render = (v: number) => { el.textContent = prefix + v.toFixed(decimals) + suffix; };
        if (reduce) { el.dataset.counted = "1"; render(target); return; }
        inView(el, () => {
          el.dataset.counted = "1";
          const dur = 1100;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - start) / dur);
            render(target * (1 - Math.pow(1 - p, 3)));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }, { amount: 0.6 });
      });
    }

    document.addEventListener("astro:page-load", () => { setupCompare(); setupCountUp(); });
  </script>
</Layout>
