---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../consts";

const title = "Harris Pumps & Filtration Case Study | Pump & Filtration Leads | Hyper Digital";
const description =
  "How we nearly halved Harris Pumps & Filtration's cost per lead and grew their leads year after year with Google Ads. One of our very first clients, and 2026 is their most efficient year yet.";

const client = "Harris Pumps & Filtration";
const trade = "Trade supply / Pumps";
const region = "New Zealand";

// ── At-a-glance (verified rates and unit cost) ──────────────────────────────
const glance: any[] = [
  { value: 17, prefix: "$", suffix: "", decimals: 0, label: "cost per lead, down from $31" },
  { value: 29, prefix: "+", suffix: "%", decimals: 0, label: "more tracked leads" },
  { value: 35, prefix: "+", suffix: "%", decimals: 0, label: "phone enquiries year-on-year" },
  { static: "Day one", label: "a client since the very beginning" },
];

// ── What we did ─────────────────────────────────────────────────────────────
const work = [
  { icon: "megaphone", title: "Google Ads from day one", body: "Harris Pumps & Filtration were one of our very first clients. We have managed their Google Ads from the beginning, building it up steadily as the results came in." },
  { icon: "target", title: "Tighter targeting, year after year", body: "We keep the keywords matched to real buyer searches for pumps and filtration, and prune anything off-intent, so the budget only chases work that converts." },
  { icon: "trend", title: "More efficient every year", body: "Each year we refine the account further. Cost per lead has come down while lead volume has gone up, which is what makes 2026 their most efficient year yet." },
  { icon: "search", title: "Customised solutions that work", body: "No off-the-shelf setup. The account is shaped around how their customers actually search and buy, and we adjust it as the market moves." },
];

// ── What stands out ─────────────────────────────────────────────────────────
const standout = [
  "Cost per lead cut from around $31 to around $17, nearly halved.",
  "29% more tracked leads, year on year.",
  "Phone enquiries up 35% year on year.",
  "One of our very first clients, and 2026 is their most efficient year yet.",
  "Customised solutions, refined every single year.",
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Results", item: "https://hyperdigital.nz/results" },
    { "@type": "ListItem", position: 2, name: `${client} case study`, item: "https://hyperdigital.nz/results/harris-pumps" },
  ],
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${client} case study: cost per lead nearly halved with Google Ads`,
  about: trade,
  author: { "@type": "Organization", name: "Hyper Digital" },
  publisher: { "@type": "Organization", name: "Hyper Digital" },
  description,
};
const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: { "@type": "Organization", name: "Hyper Digital" },
  reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
  author: { "@type": "Person", name: "Stephen Harris" },
  reviewBody:
    "Harris Pumps and Filtration have been a client of Hyper Digital from the very beginning. A great company that has helped grow our online advertising with real results. They offer customised solutions that work.",
};
---
<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1160px] px-5 py-14 sm:py-20">
      <Reveal>
        <nav class="text-sm text-neutral-content/60" aria-label="Breadcrumb">
          <a href="/results" class="transition-colors hover:text-primary">Results</a>
          <span class="px-2">/</span>
          <span class="text-neutral-content/90">{client}</span>
        </nav>
      </Reveal>
      <div class="mt-8 grid grid-cols-1 items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="text-center lg:text-left">
          <Reveal>
            <span class="badge badge-primary font-display">Case study · {trade}</span>
          </Reveal>
          <Reveal delay={0.05} class="mt-4">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl">
              Cost per lead <span class="marker">nearly halved</span>, and the leads keep growing.
            </h1>
          </Reveal>
          <Reveal delay={0.1} class="mt-5">
            <p class="text-sm uppercase tracking-wider text-primary">{region}</p>
          </Reveal>
          <Reveal delay={0.14} class="mt-5">
            <p class="mx-auto max-w-xl text-lg text-neutral-content/80 lg:mx-0">
              Harris Pumps & Filtration have been with us from the very beginning, one of our very first
              clients. Year after year we have grown their online advertising and made it leaner, cutting
              the cost of every lead while bringing in more of them. 2026 is their most efficient year yet.
            </p>
          </Reveal>
          <Reveal delay={0.2} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row lg:justify-start">
            <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">Get my free audit</a>
            <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
          </Reveal>
        </div>

        <!-- Hero media — client -->
        <Reveal delay={0.15}>
          <img
            src="/img/case-studies/harris-pumps.jpg"
            alt="Harris Pumps & Filtration"
            loading="eager"
            class="aspect-[4/3] w-full rounded-box border border-base-300 object-cover shadow-xl"
          />
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== AT A GLANCE (count-up) ===== -->
  <section class="border-b border-base-300 bg-base-100 py-10 sm:py-12">
    <div class="mx-auto max-w-[1160px] px-5">
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {glance.map((g) => (
          <div class="text-center">
            {g.static ? (
              <div class="font-display text-3xl text-primary sm:text-4xl">{g.static}</div>
            ) : (
              <div
                class="font-display text-3xl text-primary sm:text-4xl"
                data-countup={g.value}
                data-prefix={g.prefix}
                data-suffix={g.suffix}
                data-decimals={g.decimals}
              >{g.prefix}{g.value}{g.suffix}</div>
            )}
            <div class="mt-1 text-sm text-base-content/60">{g.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE CHALLENGE ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="target" class="h-7 w-7" /></span>
        <span class="eyebrow mt-5 block">The challenge</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Steady, cost-effective leads in a competitive trade.</h2>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="text-lg text-base-content/70">
          Pumps and filtration is a competitive market, with buyers comparing options the moment they
          search. Harris Pumps & Filtration needed a dependable flow of enquiries that did not blow out
          on cost, and an advertising account that kept getting sharper rather than drifting. The goal
          was simple: more of the right leads, for less each, year after year.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== WHAT WE DID ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">What we did</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">A Google Ads account that gets better with age.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          No big reset, no churn. Just steady, hands-on management of one account, refined a little more
          every year so the results compound.
        </p>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {work.map((w, i) => (
          <Reveal delay={i * 0.07} class="h-full">
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body flex-row gap-4">
                <span class="icon-chip shrink-0"><Icon name={w.icon} class="h-6 w-6" /></span>
                <div>
                  <h3 class="font-display text-xl">{w.title}</h3>
                  <p class="mt-1 text-base-content/70">{w.body}</p>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE RESULTS (interactive cost-per-lead comparison + bullets) ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">The results</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">More leads, for a lot less each.</h2>
      </Reveal>

      <div class="mt-12 grid grid-cols-1 items-center gap-10 lg:grid-cols-2">
        <!-- Interactive cost-per-lead comparison -->
        <Reveal>
          <div data-cmp data-max="36" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm sm:p-8">
            <div class="flex items-center justify-between">
              <span class="eyebrow">Cost per lead</span>
              <span data-cmp-value class="badge badge-primary font-display">$17</span>
            </div>
            <div class="mt-5 h-9 w-full overflow-hidden rounded-full bg-base-200">
              <div class="cmp-fill"></div>
            </div>
            <div class="mt-6 flex flex-wrap gap-1 rounded-box border border-base-300 bg-base-100 p-1" role="tablist" aria-label="Compare cost per lead over time">
              <button type="button" role="tab" class="tab-btn" data-val="31" data-display="$31" aria-selected="false">When we started</button>
              <button type="button" role="tab" class="tab-btn is-active" data-val="17" data-display="$17" aria-selected="true">Today</button>
            </div>
            <p class="mt-3 text-sm text-base-content/55">
              Cost per lead is what each enquiry costs in advertising. Tap to compare. Lower is better, and we have nearly halved it while growing the number of leads.
            </p>
          </div>
        </Reveal>

        <!-- What stands out -->
        <div>
          <Reveal><h3 class="font-display text-2xl">What stands out</h3></Reveal>
          <ul class="mt-5 space-y-3">
            {standout.map((s, i) => (
              <Reveal delay={i * 0.06}>
                <li class="flex items-start gap-3 rounded-box border border-base-300 bg-base-100 p-4">
                  <span class="icon-chip shrink-0 h-10 w-10"><Icon name="check" class="h-5 w-5" /></span>
                  <span class="text-base-content/80">{s}</span>
                </li>
              </Reveal>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== THE TRAJECTORY ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1000px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="trend" class="h-7 w-7" /></span>
        <span class="eyebrow mt-5 block">The trajectory</span>
        <h2 class="mt-2 text-3xl text-neutral-content sm:text-4xl">2026 is their most efficient year yet.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-neutral-content/80">
          We do not lean on a single lucky month. Across the whole partnership the trend has been the
          same: more leads, at a lower cost, year after year. The longer we work together, the better
          it gets.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== TESTIMONIAL ===== -->
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <div class="text-2xl text-primary">★★★★★</div>
      <blockquote class="mt-4 font-display text-2xl leading-snug sm:text-3xl">
        "Harris Pumps and Filtration have been a client of Hyper Digital from the very beginning. A great
        company that has helped grow our online advertising with real results. They offer customised
        solutions that work."
      </blockquote>
      <div class="mt-4 font-display text-base-content/70">Stephen Harris, Harris Pumps & Filtration</div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="shield" class="h-7 w-7" /></span>
        <h2 class="mt-5 text-3xl text-neutral-content sm:text-5xl">Want results like these for your business?</h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Hit your agreed lead goal in 60 days, or we work for free until you do. Get a free, no-obligation
          audit and we'll show you what your leads should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Get my free audit</a>
          <a href="/results" class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">See more results</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify([breadcrumbSchema, articleSchema, reviewSchema])} />

  <!-- Interactive behaviour: comparison toggle + count-up -->
  <script>
    import { inView } from "motion";

    function setupCompare() {
      document.querySelectorAll<HTMLElement>("[data-cmp]").forEach((c) => {
        if (c.dataset.bound) return;
        c.dataset.bound = "1";
        const fill = c.querySelector<HTMLElement>(".cmp-fill");
        const out = c.querySelector<HTMLElement>("[data-cmp-value]");
        const max = parseFloat(c.dataset.max || "18");
        const buttons = c.querySelectorAll<HTMLButtonElement>(".tab-btn");
        const apply = (btn: HTMLButtonElement) => {
          const val = parseFloat(btn.dataset.val || "0");
          buttons.forEach((b) => {
            const active = b === btn;
            b.classList.toggle("is-active", active);
            b.setAttribute("aria-selected", active ? "true" : "false");
          });
          if (fill) fill.style.width = Math.min(100, (val / max) * 100) + "%";
          if (out) out.textContent = btn.dataset.display || "";
        };
        buttons.forEach((b) => b.addEventListener("click", () => apply(b)));
        const init = c.querySelector<HTMLButtonElement>(".tab-btn.is-active") || buttons[0];
        if (init) apply(init);
      });
    }

    function setupCountUp() {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => {
        if (el.dataset.counted) return;
        const target = parseFloat(el.dataset.countup || "0");
        const decimals = parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const render = (v: number) => { el.textContent = prefix + v.toFixed(decimals) + suffix; };
        if (reduce) { el.dataset.counted = "1"; render(target); return; }
        inView(el, () => {
          el.dataset.counted = "1";
          const dur = 1100;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - start) / dur);
            render(target * (1 - Math.pow(1 - p, 3)));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }, { amount: 0.6 });
      });
    }

    document.addEventListener("astro:page-load", () => { setupCompare(); setupCountUp(); });
  </script>
</Layout>
