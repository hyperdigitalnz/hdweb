---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../consts";

const title = "Roofing Case Study | $45k Job From One Month of Ads | Hyper Digital";
const description =
  "How Hyper Digital manages a Hawke's Bay roofer's Google Ads for commercial intent, tracks every lead from form to won job, and traced $351 of ad spend to a $45,000 re-roof.";

const client = "Hawke's Bay Roofer";
const trade = "Roofing";
const region = "Napier · Hastings · Havelock North · Hawke's Bay";

// ── At-a-glance (conversion and revenue only — no clicks/CTR/CPC) ────────────
const glance = [
  { value: "45", prefix: "$", suffix: "k", decimals: 0, label: "in jobs won from one month of ads" },
  { value: "18", prefix: "", suffix: "", decimals: 0, label: "leads tracked as conversions" },
  { value: "20", prefix: "~$", suffix: "", decimals: 0, label: "cost per conversion" },
  { value: "19", prefix: "", suffix: "%", decimals: 0, label: "conversion rate" },
];

// ── What we did ─────────────────────────────────────────────────────────────
const work = [
  { icon: "target", title: "We optimise every campaign for commercial intent", body: "We build and manage the account around commercial intent: the searches that signal someone is ready to hire and pay for a roof, not researchers, job-seekers or browsers. Budget chases real work, not noise." },
  { icon: "search", title: "We actively remove the keywords that waste money", body: "Left unmanaged, a Google Ads search campaign leaks budget on irrelevant and low-intent searches. We read the search terms and cut the bad and irrelevant keywords as negatives, so spend goes to people ready to book a roofer." },
  { icon: "phone", title: "We track every lead from form to won job", body: "Form submissions flow straight into a CRM, so we can see which enquiries turn into won jobs. We send that result back to Google as an offline conversion, so the campaign learns from real revenue, not just clicks." },
  { icon: "trend", title: "We scale what produces jobs", body: "With won jobs feeding back into Google, we lean budget into the searches and keywords that turn into paying work, and pull it off the ones that don't. The account gets sharper every month." },
];
---
<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-14 text-center sm:py-20">
      <Reveal>
        <nav class="text-sm text-neutral-content/60" aria-label="Breadcrumb">
          <a href="/results" class="transition-colors hover:text-primary">Results</a>
          <span class="px-2">/</span>
          <span class="text-neutral-content/90">{client}</span>
        </nav>
      </Reveal>
      <Reveal class="mt-8">
        <span class="badge badge-primary font-display">Case study · {trade}</span>
      </Reveal>
      <Reveal delay={0.05} class="mt-4">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl">
          $351 in ads. A <span class="marker">$45,000 job</span>.
        </h1>
      </Reveal>
      <Reveal delay={0.1} class="mt-5">
        <p class="text-sm uppercase tracking-wider text-primary">{region}</p>
      </Reveal>
      <Reveal delay={0.14} class="mt-5">
        <p class="mx-auto max-w-xl text-lg text-neutral-content/80">
          This client is a Hawke's Bay roofer doing re-roofs, repairs, guttering and fascia. We manage
          their Google Ads around commercial intent and track every lead through to the job, so we can
          tie one month's $351 of ad spend straight to a $45,000 re-roof.
        </p>
      </Reveal>
      <Reveal delay={0.2} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
        <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">Get my free audit</a>
        <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
      </Reveal>
    </div>
  </section>

  <!-- ===== AT A GLANCE (count-up) ===== -->
  <section class="border-b border-base-300 bg-base-100 py-10 sm:py-12">
    <div class="mx-auto max-w-[1160px] px-5">
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {glance.map((g) => (
          <div class="text-center">
            <div
              class="font-display text-3xl text-primary sm:text-4xl"
              data-countup={g.value}
              data-prefix={g.prefix}
              data-suffix={g.suffix}
              data-decimals={g.decimals}
            >{g.prefix}{g.value}{g.suffix}</div>
            <div class="mt-1 text-sm text-base-content/60">{g.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE CHALLENGE ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="target" class="h-7 w-7" /></span>
        <span class="eyebrow mt-5 block">The challenge</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Win the big roofing jobs without wasting a small budget.</h2>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="text-lg text-base-content/70">
          A re-roof can be worth tens of thousands of dollars, so the searches that lead to one are
          worth winning. The catch is that roofing searches also pull in suppliers, job-seekers, DIY
          researchers and people well outside Hawke's Bay. An unmanaged campaign quietly burns budget
          on all of them. The job was to put every dollar in front of local homeowners ready to get a
          quote, and prove which spend actually turned into work.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== WHAT WE DID ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">What we did</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Manage for intent. Cut the waste. Track the jobs.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          The same search budget produces very different results depending on who manages it. Here is
          how we run it.
        </p>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {work.map((w, i) => (
          <Reveal delay={i * 0.07} class="h-full">
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body flex-row gap-4">
                <span class="icon-chip shrink-0"><Icon name={w.icon} class="h-6 w-6" /></span>
                <div>
                  <h3 class="font-display text-xl">{w.title}</h3>
                  <p class="mt-1 text-base-content/70">{w.body}</p>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW WE TRACE SPEND TO JOBS (dark feature) ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1000px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="eyebrow">How we know it worked</span>
        <h2 class="mt-2 text-3xl text-neutral-content sm:text-4xl">We can trace $351 of ads to a $45,000 job.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-neutral-content/80">
          Most agencies stop at the lead. We track every form submission into a CRM, follow it through
          to a won job, and send that result back to Google as an offline conversion. So we do not just
          count 18 leads, we can see which one became a $45,000 re-roof, and the campaign learns to go
          find more like it.
        </p>
      </Reveal>
      <Reveal class="mt-10">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { icon: "mail", label: "Lead submits a form" },
            { icon: "check", label: "Tracked through the CRM" },
            { icon: "trophy", label: "Marked won when the job lands" },
            { icon: "trend", label: "Sent to Google as a conversion" },
          ].map((t) => (
            <div class="rounded-box border border-white/10 bg-white/5 p-5 text-center">
              <span class="icon-chip mx-auto h-12 w-12"><Icon name={t.icon} class="h-6 w-6" /></span>
              <p class="mt-3 text-sm text-neutral-content/80">{t.label}</p>
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm text-neutral-content/55">Real revenue feeding the campaign, so it optimises toward jobs, not just leads.</p>
      </Reveal>
    </div>
  </section>

  <!-- ===== TESTIMONIAL (slot ready — add a verified quote here) ===== -->
  <!--
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <div class="text-2xl text-primary">★★★★★</div>
      <blockquote class="mt-4 font-display text-2xl leading-snug sm:text-3xl">"[Add a verified client quote here.]"</blockquote>
      <div class="mt-4 font-display text-base-content/70">Owner, Hawke's Bay roofer</div>
    </div>
  </section>
  -->

  <!-- ===== CTA ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="shield" class="h-7 w-7" /></span>
        <h2 class="mt-5 text-3xl text-neutral-content sm:text-5xl">Want results like these for your business?</h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Hit your agreed lead goal in 60 days, or we work for free until you do. Get a free, no-obligation
          audit and we'll show you what your leads should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Get my free audit</a>
          <a href="/results" class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">See more results</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Results", item: "https://hyperdigital.nz/results" },
        { "@type": "ListItem", position: 2, name: `${trade} case study`, item: "https://hyperdigital.nz/results/hawkes-bay-roofer" },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: "Roofing case study: a $45,000 job from one month of Google Ads",
      about: trade,
      author: { "@type": "Organization", name: "Hyper Digital" },
      publisher: { "@type": "Organization", name: "Hyper Digital" },
      description,
    },
  ])} />

  <!-- Interactive behaviour: count-up -->
  <script>
    import { inView } from "motion";

    function setupCountUp() {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => {
        if (el.dataset.counted) return;
        const target = parseFloat(el.dataset.countup || "0");
        const decimals = parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const render = (v: number) => { el.textContent = prefix + v.toFixed(decimals) + suffix; };
        if (reduce) { el.dataset.counted = "1"; render(target); return; }
        inView(el, () => {
          el.dataset.counted = "1";
          const dur = 1100;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - start) / dur);
            render(target * (1 - Math.pow(1 - p, 3)));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }, { amount: 0.6 });
      });
    }

    document.addEventListener("astro:page-load", () => { setupCountUp(); });
  </script>
</Layout>
