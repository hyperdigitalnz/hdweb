---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../consts";

const title = "Plumbing Case Study | 543 Enquiries in a Year | Hyper Digital";
const description =
  "How Hyper Digital built a Napier plumber a conversion-focused website, got it onto page 1 of Google, and runs a small Google Ads budget that delivers leads at about $13 each.";

const client = "Napier Plumber";
const trade = "Plumbing, Gas & Drainage";
const region = "Napier · Hastings · Hawke's Bay";

// ── At-a-glance (conversion and revenue only — no clicks/CTR/CPC) ────────────
const glance = [
  { value: "543", prefix: "", suffix: "", decimals: 0, label: "enquiries tracked in 12 months" },
  { value: "13", prefix: "~$", suffix: "", decimals: 0, label: "cost per Google Ads lead" },
  { value: "325", prefix: "", suffix: "", decimals: 0, label: "ads leads in 12 months" },
  { value: "1", prefix: "Page ", suffix: "", decimals: 0, label: "of Google for “plumbers napier”" },
];

// ── What we did ─────────────────────────────────────────────────────────────
const work = [
  { icon: "target", title: "We built the website to convert, not just to look good", body: "Four years ago we rebuilt their site around one job: turning a visit into a call, form or email. Clear services, click-to-call everywhere, and a simple enquiry path. Today roughly one in six visits becomes an enquiry." },
  { icon: "search", title: "We built SEO in from day one", body: "The site was structured for local search from the start: service pages, local relevance and clean technical foundations. Four years on it sits on page 1 of Google for searches like “plumbers napier”, bringing in enquiries that cost nothing per click." },
  { icon: "trend", title: "We run a small ads budget hard", body: "Around $350 a month of Google Ads spend, managed around the searches that book work: plumbers, gasfitters and drainlayers near me. Over the last year that produced 325 leads at about $13 each." },
  { icon: "phone", title: "We track every call, form and email", body: "Phone clicks, form submissions and email clicks are all tracked as conversions. Nothing is guessed: the client can open their own analytics and count all 543 enquiries themselves." },
];
---
<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-14 text-center sm:py-20">
      <Reveal>
        <nav class="text-sm text-neutral-content/60" aria-label="Breadcrumb">
          <a href="/results" class="transition-colors hover:text-primary">Results</a>
          <span class="px-2">/</span>
          <span class="text-neutral-content/90">{client}</span>
        </nav>
      </Reveal>
      <Reveal class="mt-8">
        <span class="badge badge-primary font-display">Case study · {trade}</span>
      </Reveal>
      <Reveal delay={0.05} class="mt-4">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl">
          <span class="marker">543 enquiries</span> in one year.
        </h1>
      </Reveal>
      <Reveal delay={0.1} class="mt-5">
        <p class="text-sm uppercase tracking-wider text-primary">{region}</p>
      </Reveal>
      <Reveal delay={0.14} class="mt-5">
        <p class="mx-auto max-w-xl text-lg text-neutral-content/80">
          This client is a Napier plumbing, gasfitting and drainage business. Four years ago we built
          them a website designed for conversion and SEO, and we run their Google Ads on a small
          budget. Last year the system delivered 543 tracked enquiries: 401 phone calls, 93 forms and
          49 emails.
        </p>
      </Reveal>
      <Reveal delay={0.2} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
        <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">Get my free audit</a>
        <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
      </Reveal>
    </div>
  </section>

  <!-- ===== AT A GLANCE (count-up) ===== -->
  <section class="border-b border-base-300 bg-base-100 py-10 sm:py-12">
    <div class="mx-auto max-w-[1160px] px-5">
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {glance.map((g) => (
          <div class="text-center">
            <div
              class="font-display text-3xl text-primary sm:text-4xl"
              data-countup={g.value}
              data-prefix={g.prefix}
              data-suffix={g.suffix}
              data-decimals={g.decimals}
            >{g.prefix}{g.value}{g.suffix}</div>
            <div class="mt-1 text-sm text-base-content/60">{g.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE CHALLENGE ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="target" class="h-7 w-7" /></span>
        <span class="eyebrow mt-5 block">The challenge</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Steady enquiries in a crowded local trade, on a modest budget.</h2>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="text-lg text-base-content/70">
          Plumbing is one of the most contested trades in local search. Every plumber, gasfitter and
          drainlayer in Hawke's Bay wants the same handful of searches, and big franchise operators
          outspend the locals. This client did not want to buy their way to the top with a huge ad
          budget. The job was to build an asset that earns leads on its own: a website that ranks and
          converts, backed by a small, tightly managed ads campaign, with every enquiry counted so
          nothing rests on gut feel.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== WHAT WE DID ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">What we did</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Build the site right. Rank it. Back it with ads.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          One website doing three jobs: converting visitors, earning free traffic from Google, and
          landing the paid clicks.
        </p>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {work.map((w, i) => (
          <Reveal delay={i * 0.07} class="h-full">
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body flex-row gap-4">
                <span class="icon-chip shrink-0"><Icon name={w.icon} class="h-6 w-6" /></span>
                <div>
                  <h3 class="font-display text-xl">{w.title}</h3>
                  <p class="mt-1 text-base-content/70">{w.body}</p>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== EVERY ENQUIRY COUNTED (dark feature) ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1000px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="eyebrow">How we know it worked</span>
        <h2 class="mt-2 text-3xl text-neutral-content sm:text-4xl">543 enquiries, every one of them counted.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-neutral-content/80">
          Most trade websites have no idea how many leads they produce. This one counts everything:
          every click to call, every form submission and every email click is tracked as a conversion
          in the client's own analytics. Over the last 12 months that adds up to 543 enquiries, and
          the client can verify every number themselves.
        </p>
      </Reveal>
      <Reveal class="mt-10">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { icon: "phone", label: "401 phone calls" },
            { icon: "mail", label: "93 form submissions" },
            { icon: "check", label: "49 email enquiries" },
            { icon: "trophy", label: "543 tracked enquiries in a year" },
          ].map((t) => (
            <div class="rounded-box border border-white/10 bg-white/5 p-5 text-center">
              <span class="icon-chip mx-auto h-12 w-12"><Icon name={t.icon} class="h-6 w-6" /></span>
              <p class="mt-3 text-sm text-neutral-content/80">{t.label}</p>
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm text-neutral-content/55">Numbers from the client's own analytics and Google Ads accounts, last 12 months.</p>
      </Reveal>
    </div>
  </section>

  <!-- ===== TESTIMONIAL (slot ready — add a verified quote here) ===== -->
  <!--
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <div class="text-2xl text-primary">★★★★★</div>
      <blockquote class="mt-4 font-display text-2xl leading-snug sm:text-3xl">"[Add a verified client quote here.]"</blockquote>
      <div class="mt-4 font-display text-base-content/70">Owner, Napier plumbing business</div>
    </div>
  </section>
  -->

  <!-- ===== CTA ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="shield" class="h-7 w-7" /></span>
        <h2 class="mt-5 text-3xl text-neutral-content sm:text-5xl">Want results like these for your business?</h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Hit your agreed lead goal in 60 days, or we work for free until you do. Get a free, no-obligation
          audit and we'll show you what your leads should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Get my free audit</a>
          <a href="/results" class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">See more results</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Results", item: "https://hyperdigital.nz/results" },
        { "@type": "ListItem", position: 2, name: `${trade} case study`, item: "https://hyperdigital.nz/results/napier-plumber" },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: "Plumbing case study: 543 tracked enquiries in a year from one website and a small ads budget",
      about: trade,
      author: { "@type": "Organization", name: "Hyper Digital" },
      publisher: { "@type": "Organization", name: "Hyper Digital" },
      description,
    },
  ])} />

  <!-- Interactive behaviour: count-up -->
  <script>
    import { inView } from "motion";

    function setupCountUp() {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => {
        if (el.dataset.counted) return;
        const target = parseFloat(el.dataset.countup || "0");
        const decimals = parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const render = (v: number) => { el.textContent = prefix + v.toFixed(decimals) + suffix; };
        if (reduce) { el.dataset.counted = "1"; render(target); return; }
        inView(el, () => {
          el.dataset.counted = "1";
          const dur = 1100;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - start) / dur);
            render(target * (1 - Math.pow(1 - p, 3)));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }, { amount: 0.6 });
      });
    }

    document.addEventListener("astro:page-load", () => { setupCountUp(); });
  </script>
</Layout>
