---
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.astro";
import Icon from "../../components/Icon.astro";
import { SITE } from "../../consts";

const title = "No Drips Case Study | Hawke's Bay Plumbing Leads | Hyper Digital";
const description =
  "How Hyper Digital took over No Drips' Google Ads, cut close to $3,000 of wasted spend left by the previous agency, and now drives Hawke's Bay plumbing leads from as little as $14, well under their $45 target, at click-through rates around double the industry average.";

const client = "No Drips";
const trade = "Plumbing & Gas";
const region = "Napier · Hastings · Havelock North · Central Hawke's Bay";

// ── At-a-glance (rates and unit cost only — no lead volumes) ─────────────────
const glance = [
  { value: "14", prefix: "$", suffix: "", decimals: 0, label: "cost per lead on our best keywords" },
  { value: "45", prefix: "$", suffix: "", decimals: 0, label: "their cost-per-lead target" },
  { value: "9.4", prefix: "", suffix: "%", decimals: 1, label: "click-through rate, about double the average" },
  { value: "3", prefix: "$", suffix: "k", decimals: 0, label: "wasted spend cut from the previous agency" },
];

// ── What we did ─────────────────────────────────────────────────────────────
const work = [
  { icon: "search", title: "Structured the account around real jobs", body: "We took over an account from another agency and rebuilt it. Separate, tightly managed Search campaigns for the work that matters: general plumbing, hot water, drainage, emergencies and gas, each aimed at how Hawke's Bay people actually search." },
  { icon: "target", title: "Cut the inherited waste", body: "A full search-terms audit found close to $3,000 the previous agency had spent on clicks that never turned into work: heat-pump shoppers, manufacturer brand searches, out-of-area clicks and DIY price research. We added them as negatives so budget goes to people ready to book a plumber." },
  { icon: "trend", title: "Scaled the winners", body: "We lean budget into the keywords that turn into booked jobs and pull back on the ones that don't. The best now bring in leads for as little as $14, well under their $45 target." },
  { icon: "megaphone", title: "Tracking that proves it", body: "Phone clicks, email clicks and form submissions are all tracked through Google Tag Manager into Analytics, so every reported lead is a real call or enquiry the client can verify." },
];

// ── What stands out (rates and unit cost only) ──────────────────────────────
const standout = [
  "Click-through rate of around 9%, roughly double the 3 to 5% industry average for Search ads.",
  "Our best-performing keywords bring in leads for as little as $14, well under the $45 target.",
  "Close to $3,000 of wasted spend left by the previous agency, found in the search terms and cut.",
  "An average cost of about $5 a click, so winning a plumbing job costs only a few dollars in ads.",
];

// ── Google search ad mockup (illustrative of high-intent local search) ───────
const ad = {
  query: "emergency plumber hastings",
  displayUrl: "nodrips.nz/plumbing",
  headline: "No Drips Plumbing | Fast Hawke's Bay Plumbers",
  desc: "Blocked drains, leaks, hot water and gas. Local Napier and Hastings plumbers. Call today.",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Results", item: "https://hyperdigital.nz/results" },
    { "@type": "ListItem", position: 2, name: `${client} case study`, item: "https://hyperdigital.nz/results/no-drips" },
  ],
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${client} case study: plumbing leads under the $100 target`,
  about: trade,
  author: { "@type": "Organization", name: "Hyper Digital" },
  publisher: { "@type": "Organization", name: "Hyper Digital" },
  description,
};
---
<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1160px] px-5 py-14 sm:py-20">
      <Reveal>
        <nav class="text-sm text-neutral-content/60" aria-label="Breadcrumb">
          <a href="/results" class="transition-colors hover:text-primary">Results</a>
          <span class="px-2">/</span>
          <span class="text-neutral-content/90">{client}</span>
        </nav>
      </Reveal>
      <div class="mt-8 grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="text-center lg:text-left">
          <Reveal>
            <span class="badge badge-primary font-display">Case study · {trade}</span>
          </Reveal>
          <Reveal delay={0.05} class="mt-4">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl">
              Plumbing leads from <span class="marker">as little as $14</span>.
            </h1>
          </Reveal>
          <Reveal delay={0.1} class="mt-5">
            <p class="text-sm uppercase tracking-wider text-primary">{region}</p>
          </Reveal>
          <Reveal delay={0.14} class="mt-5">
            <p class="mx-auto max-w-xl text-lg text-neutral-content/80 lg:mx-0">
              No Drips are Hawke's Bay plumbers and gasfitters who need the phone ringing for
              emergencies, hot water, drainage and new-build work. Their target is $45 a lead. We took
              over their Google Ads from another agency, cut the wasted spend, and now the best
              keywords bring in leads for as little as $14.
            </p>
          </Reveal>
          <Reveal delay={0.2} class="mt-8 flex flex-col flex-wrap justify-center gap-3 sm:flex-row lg:justify-start">
            <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 transition-transform hover:scale-[1.03] sm:w-auto">Get my free audit</a>
            <a href={SITE.phoneHref} class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">Or call {SITE.phone}</a>
          </Reveal>
        </div>

        <!-- Hero media — client website -->
        <Reveal delay={0.15}>
          <img
            src="/img/case-studies/no-drips/no-drips-main-hero-shot.jpg"
            alt="No Drips, Hawke's Bay plumbers and gasfitters"
            loading="eager"
            class="aspect-[4/3] w-full rounded-box border border-base-300 object-cover shadow-xl"
          />
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== AT A GLANCE (count-up) ===== -->
  <section class="border-b border-base-300 bg-base-100 py-10 sm:py-12">
    <div class="mx-auto max-w-[1160px] px-5">
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {glance.map((g) => (
          <div class="text-center">
            <div
              class="font-display text-3xl text-primary sm:text-4xl"
              data-countup={g.value}
              data-prefix={g.prefix}
              data-suffix={g.suffix}
              data-decimals={g.decimals}
            >{g.prefix}{g.value}{g.suffix}</div>
            <div class="mt-1 text-sm text-base-content/60">{g.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THE CHALLENGE ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="target" class="h-7 w-7" /></span>
        <span class="eyebrow mt-5 block">The challenge</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Win the high-intent jobs without burning budget.</h2>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="text-lg text-base-content/70">
          Plumbing demand is some of the highest intent there is. When a pipe bursts or the hot water
          dies, people search and call within minutes. The trouble is that the same searches pull in
          plenty of non-buyers: people shopping for heat-pump cylinders, comparing manufacturer prices,
          looking up DIY fixes, or sitting well outside Hawke's Bay. No Drips needed to be first in
          front of the ready-to-book locals, and stop paying for everyone else.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ===== WHAT WE DID ===== -->
  <section class="bg-grid-soft border-y border-base-300 py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">What we did</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">A tighter account, aimed at people ready to book.</h2>
        <p class="mt-4 text-lg text-base-content/70">
          Structure the campaigns around the real jobs, cut the spend that never converts, and pour
          budget into the keywords that turn into booked work.
        </p>
      </Reveal>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {work.map((w, i) => (
          <Reveal delay={i * 0.07} class="h-full">
            <div class="card card-glow h-full border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body flex-row gap-4">
                <span class="icon-chip shrink-0"><Icon name={w.icon} class="h-6 w-6" /></span>
                <div>
                  <h3 class="font-display text-xl">{w.title}</h3>
                  <p class="mt-1 text-base-content/70">{w.body}</p>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>

      <!-- Google search ad mockup -->
      <div class="mx-auto mt-12 max-w-[520px]">
        <Reveal>
          <div class="overflow-hidden rounded-box border border-base-300 bg-white shadow-xl">
            <div class="flex items-center gap-3 border-b border-neutral-200 px-4 py-3">
              <div class="flex gap-1" aria-hidden="true">
                <span class="h-2.5 w-2.5 rounded-full" style="background:#4285F4"></span>
                <span class="h-2.5 w-2.5 rounded-full" style="background:#EA4335"></span>
                <span class="h-2.5 w-2.5 rounded-full" style="background:#FBBC05"></span>
                <span class="h-2.5 w-2.5 rounded-full" style="background:#34A853"></span>
              </div>
              <div class="flex flex-1 items-center justify-between rounded-full border border-neutral-200 px-4 py-1.5">
                <span class="text-sm text-neutral-700">{ad.query}</span>
                <span class="text-neutral-400"><Icon name="search" class="h-4 w-4" /></span>
              </div>
            </div>
            <div class="px-4 py-4 text-left">
              <div class="text-[13px] font-semibold text-neutral-800">Sponsored</div>
              <div class="mt-1.5 flex items-center gap-2">
                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-base-200 font-display text-sm text-primary">N</span>
                <div class="leading-tight">
                  <div class="text-[13px] font-medium text-neutral-900">No Drips</div>
                  <div class="text-xs text-neutral-600">{ad.displayUrl}</div>
                </div>
              </div>
              <span class="mt-2 block text-[20px] leading-snug text-[#1a0dab]">{ad.headline}</span>
              <p class="mt-1 text-sm leading-snug text-neutral-700">{ad.desc}</p>
            </div>
          </div>
          <p class="mt-2 text-center text-xs text-base-content/50">Illustrative of how No Drips shows up for high-intent local searches.</p>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ===== THE RESULTS (interactive CPA-vs-target comparison + bullets) ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-[1160px] px-5">
      <Reveal class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">The results</span>
        <h2 class="mt-2 text-3xl sm:text-4xl">Real calls and quote requests, under target.</h2>
      </Reveal>

      <div class="mt-12 grid items-center gap-10 lg:grid-cols-2">
        <!-- Interactive target vs best-keyword comparison -->
        <Reveal>
          <div data-cmp data-max="45" class="rounded-box border border-base-300 bg-base-100 p-6 shadow-sm sm:p-8">
            <div class="flex items-center justify-between">
              <span class="eyebrow">Cost per lead</span>
              <span data-cmp-value class="badge badge-primary font-display">$14</span>
            </div>
            <div class="mt-5 h-9 w-full overflow-hidden rounded-full bg-base-200">
              <div class="cmp-fill"></div>
            </div>
            <div class="mt-6 flex flex-wrap gap-1 rounded-box border border-base-300 bg-base-100 p-1" role="tablist" aria-label="Compare cost per lead to target">
              <button type="button" role="tab" class="tab-btn" data-val="45" data-display="$45" aria-selected="false">Their target</button>
              <button type="button" role="tab" class="tab-btn is-active" data-val="14" data-display="$14" aria-selected="true">Best keywords</button>
            </div>
            <p class="mt-3 text-sm text-base-content/55">
              Their target is $45 a lead. Tap to compare. Lower is better, and our best-performing keywords bring leads in at just $14, for plumbing jobs often worth hundreds of dollars.
            </p>
          </div>
        </Reveal>

        <!-- What stands out -->
        <div>
          <Reveal><h3 class="font-display text-2xl">What stands out</h3></Reveal>
          <ul class="mt-5 space-y-3">
            {standout.map((s, i) => (
              <Reveal delay={i * 0.06}>
                <li class="flex items-start gap-3 rounded-box border border-base-300 bg-base-100 p-4">
                  <span class="icon-chip shrink-0 h-10 w-10"><Icon name="check" class="h-5 w-5" /></span>
                  <span class="text-base-content/80">{s}</span>
                </li>
              </Reveal>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CUT THE WASTE (dark feature) ===== -->
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[1000px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="eyebrow">The number that matters</span>
        <h2 class="mt-2 text-3xl text-neutral-content sm:text-4xl">Close to $3,000 of inherited waste, found and cut.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-neutral-content/80">
          When we took the account over from the previous agency, we read the search terms one by one
          to see exactly what people typed before they clicked. The non-buyers stood out fast. We
          turned each theme into a negative keyword so the budget stops chasing them and goes back into
          work that books.
        </p>
      </Reveal>
      <Reveal class="mt-10">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { icon: "search", label: "Heat-pump shoppers" },
            { icon: "trophy", label: "Manufacturer brand searches" },
            { icon: "pin", label: "Out-of-area clicks" },
            { icon: "target", label: "DIY and price research" },
          ].map((t) => (
            <div class="rounded-box border border-white/10 bg-white/5 p-5 text-center">
              <span class="icon-chip mx-auto h-12 w-12"><Icon name={t.icon} class="h-6 w-6" /></span>
              <p class="mt-3 text-sm text-neutral-content/80">{t.label}</p>
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm text-neutral-content/55">Spend on terms with zero conversions, identified across the account's search-terms history and excluded.</p>
      </Reveal>
    </div>
  </section>

  <!-- ===== TESTIMONIAL (slot ready — add a verified quote here) ===== -->
  <!--
  <section class="bg-base-200 py-16 sm:py-20">
    <div class="mx-auto max-w-[820px] px-5 text-center">
      <div class="text-2xl text-primary">★★★★★</div>
      <blockquote class="mt-4 font-display text-2xl leading-snug sm:text-3xl">"[Add a verified Google review or client quote here.]"</blockquote>
      <div class="mt-4 font-display text-base-content/70">Owner name, No Drips</div>
    </div>
  </section>
  -->

  <!-- ===== CTA ===== -->
  <section class="bg-brand-dark-2 text-neutral-content">
    <div class="mx-auto max-w-[900px] px-5 py-16 text-center sm:py-20">
      <Reveal>
        <span class="icon-chip mx-auto h-14 w-14"><Icon name="shield" class="h-7 w-7" /></span>
        <h2 class="mt-5 text-3xl text-neutral-content sm:text-5xl">Want results like these for your business?</h2>
        <p class="mx-auto mt-5 max-w-2xl text-neutral-content/80">
          Hit your agreed lead goal in 60 days, or we work for free until you do. Get a free, no-obligation
          audit and we'll show you what your leads should cost.
        </p>
        <div class="mt-7 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Get my free audit</a>
          <a href="/results" class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">See more results</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify([breadcrumbSchema, articleSchema])} />

  <!-- Interactive behaviour: comparison toggle + count-up -->
  <script>
    import { inView } from "motion";

    function setupCompare() {
      document.querySelectorAll<HTMLElement>("[data-cmp]").forEach((c) => {
        if (c.dataset.bound) return;
        c.dataset.bound = "1";
        const fill = c.querySelector<HTMLElement>(".cmp-fill");
        const out = c.querySelector<HTMLElement>("[data-cmp-value]");
        const max = parseFloat(c.dataset.max || "100");
        const buttons = c.querySelectorAll<HTMLButtonElement>(".tab-btn");
        const apply = (btn: HTMLButtonElement) => {
          const val = parseFloat(btn.dataset.val || "0");
          buttons.forEach((b) => {
            const active = b === btn;
            b.classList.toggle("is-active", active);
            b.setAttribute("aria-selected", active ? "true" : "false");
          });
          if (fill) fill.style.width = Math.min(100, (val / max) * 100) + "%";
          if (out) out.textContent = btn.dataset.display || "";
        };
        buttons.forEach((b) => b.addEventListener("click", () => apply(b)));
        const init = c.querySelector<HTMLButtonElement>(".tab-btn.is-active") || buttons[0];
        if (init) apply(init);
      });
    }

    function setupCountUp() {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => {
        if (el.dataset.counted) return;
        const target = parseFloat(el.dataset.countup || "0");
        const decimals = parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const render = (v: number) => { el.textContent = prefix + v.toFixed(decimals) + suffix; };
        if (reduce) { el.dataset.counted = "1"; render(target); return; }
        inView(el, () => {
          el.dataset.counted = "1";
          const dur = 1100;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - start) / dur);
            render(target * (1 - Math.pow(1 - p, 3)));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }, { amount: 0.6 });
      });
    }

    document.addEventListener("astro:page-load", () => { setupCompare(); setupCountUp(); });
  </script>
</Layout>
