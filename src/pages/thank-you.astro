---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import { SITE } from "../consts";

const title = "Thank you | Hyper Digital";
const description = "Your request is in. We'll be in touch within one business day with your free audit.";
---
<Layout title={title} description={description} noindex={true} hideHeader={true}>
  <section class="bg-brand-dark text-neutral-content">
    <div class="mx-auto max-w-[820px] px-5 py-24 text-center sm:py-32">
      <Reveal>
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary text-3xl text-primary-content">✓</div>
        <span class="eyebrow mt-6 block">Request received</span>
        <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl">Now book your <span class="marker">free audit</span>.</h1>
      </Reveal>
      <Reveal delay={0.08} class="mt-5">
        <p class="mx-auto max-w-xl text-lg text-neutral-content/80">
          Your details are in and a confirmation is on its way to your inbox. Pick a time that suits
          you below and we'll have your free audit ready to walk through.
        </p>
      </Reveal>
      <Reveal delay={0.14} class="mt-10">
        <div class="mx-auto max-w-[760px] rounded-box bg-base-100 p-3 shadow-xl sm:p-4">
          <!-- src is set by the prefill script below (base URL + any form-prefill params).
               The GHL calendar needs JS to function/resize anyway, so no static src is lost. -->
          <iframe
            data-base-src="https://api.leadconnectorhq.com/widget/booking/w3xpc9OhTq5o0cpTvnK7"
            title="Book your free audit"
            style="width:100%;border:none;overflow:hidden;min-height:680px;"
            scrolling="no"
            id="w3xpc9OhTq5o0cpTvnK7_1782263208027"
          ></iframe>
        </div>
      </Reveal>
      <Reveal delay={0.2} class="mt-10 flex flex-col flex-wrap justify-center gap-3 sm:flex-row">
        <a href={SITE.phoneHref} class="btn btn-primary btn-lg w-full font-display text-lg tracking-wide shadow-lg shadow-primary/30 sm:w-auto">Call {SITE.phone}</a>
        <a href="/results" class="btn btn-outline btn-lg w-full border-primary text-primary hover:bg-primary hover:text-primary-content font-display text-lg tracking-wide sm:w-auto">See our results</a>
      </Reveal>
      <Reveal delay={0.26} class="mt-8">
        <a href="/" class="text-sm uppercase tracking-wider text-neutral-content/50 transition-colors hover:text-primary">← Back to home</a>
      </Reveal>
    </div>
  </section>

  <!-- Prefill the GHL calendar from the audit form (stashed in sessionStorage on submit).
       Builds the iframe src client-side so PII never touches our URL/history/server logs. -->
  <script is:inline>
    (function () {
      var iframe = document.getElementById("w3xpc9OhTq5o0cpTvnK7_1782263208027");
      if (!iframe) return;
      var base = iframe.getAttribute("data-base-src");
      var src = base;
      try {
        var raw = sessionStorage.getItem("af_prefill");
        if (raw) {
          var d = JSON.parse(raw);
          var p = new URLSearchParams();
          var name = (d.name || "").trim();
          if (name) {
            // GHL prefills a field only when the param KEY matches that field's name, and the
            // calendar has no "full_name" field. Its name field is first_name / last_name, so a
            // single full-name param can't populate it. Split on the first space (last name = the
            // rest); send both underscore and no-underscore variants to cover either field naming.
            var sp = name.indexOf(" ");
            var first = sp === -1 ? name : name.slice(0, sp);
            var last = sp === -1 ? "" : name.slice(sp + 1).trim();
            p.set("first_name", first);
            p.set("firstname", first);
            if (last) { p.set("last_name", last); p.set("lastname", last); }
          }
          if (d.email) p.set("email", d.email);
          // "website" is not a default GHL calendar field. Sent best-effort (GHL ignores
          // unknown params). To actually populate it, add a custom field to the calendar
          // and swap "website" below for that field's key.
          if (d.website) p.set("website", d.website);
          var qs = p.toString();
          if (qs) src = base + "?" + qs;
          sessionStorage.removeItem("af_prefill"); // one-shot: don't leak into a refresh/back-nav
        }
      } catch (e) { /* malformed/blocked storage — fall back to the base calendar */ }
      iframe.src = src;
    })();
  </script>

  <!-- GHL booking widget resizer: sizes the calendar iframe to its content via its id. -->
  <script is:inline src="https://api.leadconnectorhq.com/js/form_embed.js"></script>

  <!-- Fire the Google Ads conversion once the lead lands here (verified server-side before redirect). -->
  <script is:inline>
    if (typeof window.gtag === "function") {
      window.gtag("event", "conversion", { send_to: "AW-703611224/KEGlCPfXyr4cENiCwc8C" });
    }
  </script>
</Layout>
